

                ;  ACUTER - CUTER MODIFIED FOR ALTAIR 8800.
                ;
                ;     Console (pseudo device 0): 1st 2SIO port
                ;     Serial (pseudo device 1): 2nd 2SIO port
                ;     Parallel (pseudo device 2): PIO port
                ;     Tape I/O commands use the Altair ACR.
                ;
                ;     HGET command added to input an Intel hex file
                ;	HGET [pseudo-port]
                ;
                ;     HSAVE command added to save an Intel hex file
                ;	HSAVE start end [pseudo-port]
                ;
                ;     Commands can be aborted with CTRL-@ as with CUTER
                ;
                ;     Console output does not attempt to emulate VDM
                ;     functions with terminal escape sequences.
                ;
                ;     Be sure to configure RAM and ROM addresses for
                ;     your system below.
                ;
                ;     Ver    Date	Author		Notes
                ;     1.0  04/25/2015  M. Douglas	Original
                ;
                ;-----------------------------------------------------------
                ;
                ;
                ;
                ;        CUTER(TM)
                ;
                ;                 COPYRIGHT (C) 1977
                ;                 SOFTWARE TECHNOLOGY CORP.
                ;                 P.O. BOX 5260
                ;                 SAN MATEO, CA 94402
                ;                 (415) 349-8080
                ;
                ;    A L L    R I G H T S   R E S E R V E D ! ! !
                ;
                ;
                ;        VERSION  1.3
                ;                 77-03-27
                ;
                ;
                ;  THIS PROGRAM IS DESIGNED TO BE A STANDALONE CUTS
                ;  OPERATING SYSTEM. CUTER IS DESIGNED TO BE READ IN FROM
                ;  CASSETTE TAPE OR TO BE RESIDENT IN READ-ONLY-MEMORY.
                ;  CUTER SUPPORTS VARIOUS DEVICES INCLUDING SERIAL,
                ;  PARALLEL, THE PROCESSOR TECHNOLOGY VDM(TM) AND UP TO
                ;  TWO CUTS TAPE DRIVES.
                ;
                ;  CUTER(TM) HAS BEEN WRITTEN SO AS TO BE COMPATIBLE WITH
                ;  SOLOS(TM).  THE FOLLOWING KEYS ARE USED BY CUTER(TM)
                ;  IN PLACE OF THE SPECIAL KEYS ON THE SOL KEYBOARD:
                ;
                ;     MODE            CTL-@
                ;
                ;
                
 F000           	ORG	0F000H	;CUTER ROM BASE ADDRESS
 BC00 =         RAMADDR	EQU	0BC00H	;CUTER RAM BASE ADDRESS (1K REQUIRED)
                ;
                ;
                ;   AUTO-STARTUP CODE
                ;
 F000 7F        START:	MOV	A,A	;SHOW THIS IS CUTER (SOLOS=00)
 F001 C381F0    INIT:	JMP	STRTA	;SYSTEM RESTART ENTRY POINT
                ;
                ;   THESE JUMP POINTS ARE PROVIDED TO ALLOW COMMON ENTRY
                ; LOCATIONS FOR ALL VERSIONS OF CUTER.  THEY ARE USED
                ; EXTENSIVELY BY CUTS SYSTEM PROGRAMS AND IT IS RECOMMENDED
                ; THAT USER ROUTINES ACCESS CUTER ROUTINES THROUGH THESE
                ; POINTS ONLY!
                ;
 F004 C3C3F0    RETRN:	JMP	COMND	;RETURN TO CUTER COMMAND PROCESSOR
 F007 C352F4    FOPEN:	JMP	BOPEN	;CASSETTE OPEN FILE ENTRY
 F00A C375F4    FCLOS:	JMP	PCLOS	;CASSETTE CLOSE FILE ENTRY
 F00D C3B8F4    RDBYT:	JMP	RTBYT	;CASSETTE READ BYTE ENTRY
 F010 C3F5F4    WRBYT:	JMP	WTBYT	;CASSETTE WRITE BYTE ENTRY
 F013 C33DF5    RDBLK:	JMP	RTAPE	;CASSETTE READ BLOCK ENTRY
 F016 C3F2F5    WRBLK:	JMP	WTAPE	;CASSETTE WRITE BLOCK ENTRY
                ;
                ;     SYSTEM I/O ENTRY POINTS
                ;
                ;  THESE FOUR ENTRY POINTS ARE USED TO EITHER INPUT
                ;  OR OUTPUT TO CUTER PSUEDO PORTS.
                ;  THESE PSUEDO PORTS ARE AS FOLLOWS:
                ;
                ;  PORT   INPUT              OUTPUT
                ;  ----   -----------------  ---------------------
                ;   0     1ST 2SIO PORT      1ST 2SIO PORT
                ;   1     2ND 2SIO PORT	     2ND 2SIO PORT
                ;   2     PIO PARALLEL PORT  PIO PARALLEL PORT
                ;   3     USER'S INPUT RTN   USER'S OUTPUT ROUTINE
                ;
                ;
                ;  NOTE: SOUT AND SINP ARE "LDA" INSTRUCTIONS.
                ;        THIS FACT IS USED TO ALLOW ACCESS TO THE
                ;        BYTES "OPORT" AND "IPORT" DYNAMICALLY.
                ;        THESE MUST REMAIN "LDA" INSTRUCTIONS!!!!!
                ;
 F019 3A07BC    SOUT:	LDA	OPORT	;OUTPUT VIA STANDARD OUTPUT PSUEDO PORT
 F01C C32EF0    AOUT:	JMP	OUTPR	;OUTPUT VIA PSUEDO PORT SPECIFIED IN REG A
 F01F 3A06BC    SINP:	LDA	IPORT	;INPUT VIA STANDARD INPUT PSUEDO PORT
 F022 =         AINP:	EQU	$	;INPUT VIA PSUEDO PORT SPECIFIED IN REG A
                ; -----------END OF SYSTEM ENTRY POINTS----------
                ;
                ;
                ; AINP CONTINUES HERE (IT COULD HAVE BEEN A "JMP" THOUGH)
 F022 E5        	PUSH	H	;SAVE HL FM ENTRY
 F023 21A2F1    	LXI	H,ITAB
                ;
                ;    THIS ROUTINE PROCESSES THE I/O REQUESTS
                ;
 F026 E603      IOPRC:	ANI	3	;KEEP REGISTER "A" TO FOUR VALUES
 F028 07        	RLC		;COMPUTE ENTRY ADDRESS
 F029 85        	ADD	L
 F02A 6F        	MOV	L,A	;WE HAVE ADDRESS
 F02B C343F1    	JMP	DISPT	;DISPATCH TO IT
                ;
                ;
 F02E =         OUTPR:	EQU	$	;PROCESS OUTPUT REQUESTS
 F02E E5        	PUSH	H	;SAVE REGS
 F02F 219AF1    	LXI	H,OTAB	;POINT TO OUTPUT DISPATCH TABLE
 F032 C326F0    	JMP	IOPRC	;DISPATCH FOR PROPER PSUEDO PORT
                ;
                ;
                ;
                ; CUTER SYSTEM I/O ROUTINES
                ;
                ;
                ;    THIS ROUTINE IS A MODEL OF ALL INPUT ROUTINES WITHIN
                ;  CUTER.  THE FIRST ROUTINE "KREA1" PERFORMS THE INPUT
                ;  FROM THE STANDARD KEYBOARD ON PARALLEL PORT 3.
                ;  ALL STANDARD INPUT DRIVERS RETURN EITHER THE CHARACTER
                ;  WITH A NON-ZERO FLAG, OR JUST A ZERO FLAG INDICATING
                ;  THAT NO CHARACTER IS AVAILABLE YET.  IT WILL BE THE
                ;  RESPONSIBILITY OF THE USER TO LOOP WAITING FOR A
                ;  CHARACTER, OR TO USE THE INPUT AS A STATUS REQUEST.
                ;  WHEN A CHARACTER IS AVAILABLE, IT IS RETURNED IN REG A.
                ;
                ;  THE FOLLOWING KEYBOARD ROUTINE MAY BE USED AS A SAMPLE
                ;  OF HOW TO WRITE A USER INPUT ROUTINE.
                ;
                ;         KEYBOARD INPUT ROUTINE
                ;
 F035 =         KREA1:	EQU	$	;KEYBOARD READ ROUTINE
 F035 DB10      	IN	SIO1CSR	;GET STATUS WORD (1ST 2SIO PORT)
 F037 E601      	ANI	SIORDRF	;RECEIVE DATA AVAILABLE?
 F039 C8        	RZ		;ZERO IF NO CHARACTER RECEIVED
                ;
 F03A DB11      	IN	SIO1DR	;GET CHARACTER (1ST 2SIO PORT)
 F03C C9        	RET		;GO BACK WITH IT
                ;
                ;
                ;
                ;   SERIAL INPUT ROUTINE
                ;
 F03D =         SREA1:	EQU	$	;SERIAL INPUT ROUTINE
 F03D DB12      	IN	SIO2CSR	;GET STATUS (2ND 2SIO PORT)
 F03F E601      	ANI	SIORDRF	;TEST FOR SERIAL DATA READY
 F041 C8        	RZ		;FLAGS ARE SET
                ;
 F042 DB13      	IN	SIO2DR	;GET DATA BYTE (2ND 2SIO PORT)
 F044 C9        	RET		;WE HAVE IT
                ;
                ;
                ;   SERIAL DATA OUTPUT
                ;
 F045 =         SEROT:	EQU	$	;SERIAL OUTPUT ROUTINE
 F045 DB12      	IN	SIO2CSR	;GET STATUS (2ND 2SIO PORT)
 F047 E602      	ANI	SIOTDRE	
 F049 CA45F0    	JZ	SEROT	;LOOP UNTIL TRANSMITTER BUFFER IS EMPTY
 F04C 78        	MOV	A,B	;GET THE CHARACTER BACK
 F04D D313      	OUT	SIO2DR	;SEND IT OUT (2ND 2SIO PORT)
 F04F C9        	RET		;AND WE'RE DONE
                ;
                ;
                ; PARALLEL DATA INPUT
 F050 =         PARIT:	EQU	$	;GET CHAR FROM PARALLEL PORT
 F050 DB04      	IN	PIOCSR	;STATUS (PIO)
 F052 E602      	ANI	PIORDRF	;IS DATA READY?
 F054 C8        	RZ		;NO--JUST EXIT
                ;
 F055 DB05      	IN	PIODR	;YES--GET CHAR THEN
 F057 C9        	RET		;THEN EXIT
                ;
                ;
                ;  PARALLEL DATA OUTPUT ROUTINE
 F058 =         PAROT:	EQU	$	;OUTPUT CHAR TO PARALLEL PORT
 F058 DB04      	IN	PIOCSR	;STATUS (PIO)
 F05A E601      	ANI	PIOTDRE	;READY TO SEND?
 F05C CA58F0    	JZ	PAROT	;NO
 F05F 78        	MOV	A,B	;GET CHAR
 F060 D305      	OUT	PIODR	;SEND DATA NOW
 F062 C9        	RET		;DONE
                ;
                ;
                ; USER DEFINED INPUT/OUTPUT ROUTINES
 F063 =         ERRIT:	EQU	$	;USER INPUT ROUTINE
 F063 E5        	PUSH	H	;SAVE ORIG HL
 F064 2A00BC    	LHLD	UIPRT	;GET USER'S RTN ADDR
 F067 C36EF0    	JMP	ERRO1	;MERGE TO VERIFY THE ADDR
                ;
 F06A =         ERROT:	EQU	$	;USER OUTPUT ROUTINE
 F06A E5        	PUSH	H	;SAVE ORIG HL
 F06B 2A02BC    	LHLD	UOPRT	;GET USER'S RTN ADDR
 F06E =         ERRO1:	EQU	$	;WE MERGE HERE TO VFY ADDR
 F06E 7D        	MOV	A,L	;ZERO=UNDEFINED
 F06F B4        	ORA	H	;IS IT?
 F070 C247F1    	JNZ	DISP1	;NO--VALID--OFF TO IT
 F073 C3BDF0    	JMP	STRTD	;RESET I/O PORTS AND BACK TO COMMAND MODE
                ;
                ;
                ;
                ;                  VIDEO DISPLAY ROUTINES
                ;
                ;
                ;  THESE ROUTINES ALLOW FOR STANDARD VIDEO TERMINAL
                ;  OPERATIONS.  ON ENTRY, THE CHARACTER FOR OUTPUT IS IN
                ;  REGISTER B AND ALL REGISTERS ARE UNALTERED ON RETURN.
                ;
                ;
                ;
 F076 =         VDM01:	EQU	$	;VDM OUTPUT DRIVER
 F076 DB10      	IN	SIO1CSR	;GET STATUS
 F078 E602      	ANI	SIOTDRE
 F07A CA76F0    	JZ	VDM01	;LOOP UNTIL TRANSMITTER BUFFER IS EMPTY
 F07D 78        	MOV	A,B	;GET THE CHARACTER BACK
 F07E D311      	OUT	SIO1DR	;SEND IT OUT
 F080 C9        	RET
                ;
                ;
                ;
                ;                START UP SYSTEM
                ;
                ;   CLEAR SCREEN AND THE FIRST 256 BYTES OF GLOBAL RAM
                ;  THEN ENTER THE COMMAND MODE.
                ;
 F081 DB05      STRTA:	IN	PIODR	;READ PIO DATA TO INIT HANDSHAKE
 F083 3E03      	MVI	A,03H	;RESET 2SIO PORTS
 F085 D310      	OUT	SIO1CSR
 F087 D312      	OUT	SIO2CSR
 F089 3E11      	MVI	A,11H	;8N2
 F08B D310      	OUT	SIO1CSR
 F08D D312      	OUT	SIO2CSR
 F08F AF        	XRA	A
 F090 4F        	MOV	C,A
 F091 2104BC    	LXI	H,DFLTS	;CLEAR AFTER USER PORT ADDRESSES
                ;
 F094 77        CLERA:	MOV	M,A
 F095 23        	INX	H
 F096 0C        	INR	C
 F097 C294F0    	JNZ	CLERA
                ;
                ; DETERMINE THE DEFAULT PORTS
                ;     THIS COULD BECOME "MVI A,XX" FOR YOUR SPECIFIC PORTS
 F09A DBFF      	IN	SENSE	;GET SWITCHES
                ;
 F09C 47        	MOV	B,A	;SAVE IT
 F09D E603      	ANI	3	;MAKE IT A VALID PORT
 F09F 3205BC    	STA	DFLTS+1	;SET DEFAULT OUTPUT PORT
 F0A2 210000    	LXI	H,0	;USE FOR CLEARING USER ADDRESSES
 F0A5 FE03      	CPI	3	;IS IT A USER PORT
 F0A7 CAADF0    	JZ	STRTC	;YES-- DO NOT CLEAR IT
 F0AA 2202BC    	SHLD	UOPRT	;NO--CLEAR ADDR
 F0AD =         STRTC:	EQU	$	;OUTPUT PORT ALL SET
 F0AD 78        	MOV	A,B	;FM SENSE SWITCHES
 F0AE 1F        	RAR
 F0AF 1F        	RAR		;NEXT 2 BITS ARE INPUT PORT
 F0B0 E603      	ANI	3	;VALID PORT
 F0B2 3204BC    	STA	DFLTS	;THIS IS DEFAULT INPUT PORT
 F0B5 FE03      	CPI	3	;IS THIS ONE A USER PORT
 F0B7 CABDF0    	JZ	STRTD	;YES--DO NOT CLEAR IT THEN
 F0BA 2200BC    	SHLD	UIPRT	;NO--FORCE USER ADDRESS ZERO
 F0BD =         STRTD:	EQU	$	;1ST TIME INITIALIZATION ALL DONE NOW
 F0BD 2A04BC    	LHLD	DFLTS	;PICK UP DEFAULT PORTS
 F0C0 2206BC    	SHLD	IPORT	;FORCE PORTS TO DEFAULT
 F0C3 =         COMN1:	EQU	$	;HERE TO TURN OFF TAPES, THEN COMMAND MODE
                ;
                ;
                ;
                ;            =--  COMMAND MODE  --=
                ;
                ;
                ;   THIS ROUTINE GETS AND PROCESSES COMMANDS
                ;
 F0C3 31FFBF    COMND:	LXI	SP,SYSTP	;SET STACK POINTER
 F0C6 CDD3F1    	CALL	PROMPT	;PUT PROMPT ON SCREEN
 F0C9 CDD2F0    	CALL	GCLI0	;INIT TO GET COMMAND LINE
 F0CC CD26F1    	CALL	COPRC	;PROCESS THE LINE
 F0CF C3C3F0    	JMP	COMND	;OVER AND OVER
                ;
                ;
                ;
                ;   THIS ROUTINE READS A COMMAND LINE FROM THE SYSTEM
                ;  KEYBOARD
                ;
                ;  C/R   TERMINATES THE SEQUENCE ERASING ALL CHARS TO THE
                ;        RIGHT OF THE CURSOR
                ;  L/F   TERMINATES THE SEQUENCE
                ;  ESC   RESETS TO COMMAND MODE.
                ;
 F0D2 =         GCLI0:	EQU	$	;HERE TO INIT FOR GCLIN
 F0D2 215EBE    	LXI	H,INLIN-1	;PT TO CHAR IN FRONT OF INPUT BFR
 F0D5 3607      	MVI	M,7	;MAKE SURE IT IS "BELL" TO KEEP FM DEL'ING TOO FAR
 F0D7 23        	INX	H	;NOW PT TO INPUT BFR
 F0D8 2208BC    	SHLD	INPTR	;SAVE AS STARTING PTR
 F0DB 3E50      	MVI	A,80	;NUMBER OF CHARS IN LINE (MAX)
 F0DD =         GCLI1:	EQU	$	;LOOP TO BLANK OUT LINE BFR
 F0DD 3620      	MVI	M,' '	;BLANKS
 F0DF 23        	INX	H	;NEXT CHAR
 F0E0 3D        	DCR	A	;FOR THIS COUNT
 F0E1 C2DDF0    	JNZ	GCLI1	;ENTIRE LINE
 F0E4 CD1FF0    GCLIN:	CALL	SINP	;READ INPUT DEVICE
 F0E7 CAE4F0    	JZ	GCLIN
 F0EA E67F      	ANI	7FH	;MAKE SURE NO X'80' BIT DURING CMND MODE
 F0EC CABDF0    	JZ	STRTD	;IF EITHER MODE (OR CTL-@)
 F0EF 47        	MOV	B,A
 F0F0 FE0D      	CPI	CR	;IS IT CR?
 F0F2 CA19F0    	JZ	SOUT	;YES, ECHO IT AND EXIT
 F0F5 FE0A      	CPI	LF	;IS IT A LINEFEED
 F0F7 C8        	RZ		;YES--TERMINATE LINE AS IS
 F0F8 2A08BC    	LHLD	INPTR	;CRNT LINE PTR
                
                ; CHECK FOR AND PROCESS DELETE OR BACKSPACE
                
 F0FB FE7F      	CPI	7FH	;DELETE CHR?
 F0FD CA05F1    	JZ	DODEL	;YES
 F100 FE08      	CPI	BS	;BACKSPACE
 F102 C21BF1    	JNZ	GCLI2	;NO--OK
 F105 2B        DODEL:	DCX	H	;BACK UP LINE PTR
 F106 3E07      	MVI	A,'G'-40H	;SEE IF A BELL (START OF LINE)
 F108 BE        	CMP	M	;IS IT?
 F109 CAE4F0    	JZ	GCLIN	;YES, DO NOTHING
 F10C 0608      	MVI	B,BS	;ECHO BS, SPACE, BS
 F10E CD19F0    	CALL	SOUT
 F111 0620      	MVI	B,' '
 F113 CD19F0    	CALL	SOUT
 F116 0608      	MVI	B,BS
 F118 C31DF1    	JMP	GCLI3
                ;
 F11B =         GCLI2:	EQU	$	;STORE CHAR IN INPUT AREA
 F11B 70        	MOV	M,B	;PLACE CHAR INTO LINE
 F11C 23        	INX	H	;NEXT CHAR
                ;
 F11D =         GCLI3:	EQU	$	;SAVE NEW LINE PTR
 F11D 2208BC    	SHLD	INPTR	;SAVE PTR
                ;
 F120 CD19F0    	CALL	SOUT
 F123 C3E4F0    	JMP	GCLIN
                ;
                ;
                ;
                ;
                ;      FIND AND PROCESS COMMAND
                ;
 F126 =         COPRC:	EQU	$	;PROCESS THIS COMMAND LINE
 F126 CD66F1    	CALL	STUP	;SETUP TO PROCESS INPUT LINE
 F129 EB        	XCHG		;DE=ADDR
 F12A 2100F0    	LXI	H,START	;PREP SO THAT HL WILL PT TO CUTER LATER
 F12D E5        	PUSH	H	;PLACE PTR TO CUTER ON STACK FOR LATER DISPT
 F12E CD05F2    	CALL	SCHR	;SCAN PAST BLANKS
 F131 CA04F3    	JZ	ERR1	;NO COMMAND?
 F134 EB        	XCHG		;HL HAS FIRST CHR
 F135 116DF1    	LXI	D,COMTAB	;POINT TO COMMAND TABLE
 F138 CD4DF1    	CALL	FDCOM	;SEE IF IN PRIMARY TABLE
 F13B CC4AF1    	CZ	FDCOU	;TRY CUSTOM ONLY IF NOT PRIMARY COMMAND
 F13E =         DISP0:	EQU	$	;HERE TO EITHER DISPATCH OR DO ERROR
 F13E CA05F3    	JZ	ERR2	;NOT IN EITHER TABLE
 F141 13        	INX	D	;PT DE TO ADDR OF RTN
 F142 EB        	XCHG		;HL=ADDR OF ADDR OF RTN
                ; **** DROP THRU TO DISPT ***
                ;
                ; THIS ROUTINE DISPTACHES TO THE ADDR AT CONTENTS OF HL.
                ; HL ARE RESTORED PRIOR TO GOING TO ROUTINE.
                ;
 F143 =         DISPT:	EQU	$	;DISPATCH
 F143 7E        	MOV	A,M	;LOW BYTE
 F144 23        	INX	H
 F145 66        	MOV	H,M	;HI BYTE
 F146 6F        	MOV	L,A	;AND LO, HL NOW COMPLETE
 F147 =         DISP1:	EQU	$	;HERE TO GO OFF TO HL DIRECTLY
 F147 E3        	XTHL		;HL RESTORED AND ADDR ON STACK
 F148 7D        	MOV	A,L	;ALWAYS PASS L IN "A" (PRIMARILY FOR SET'S)
 F149 C9        	RET		;OFF TO ROUTINE
                ;
                ;
                ;
                ;   THIS ROUTINE SEARCHES THROUGH A TABLE, POINTED TO
                ;  BY 'DE', FOR A DOUBLE CHARACTER MATCH OF THE 'HL'
                ;  MEMORY CONTENT.  IF NO MATCH IS FOUND THE SCAN ENDS
                ;  WITH THE ZERO FLAG SET, ELSE NON-ZERO SET.
                ;
 F14A =         FDCOU:	EQU	$	;HERE TO SCAN CUSTOM TABLE
 F14A 1137BC    	LXI	D,CUTAB	;PT TO CUSTOM RTN TBL
 F14D 1A        FDCOM:	LDAX	D
 F14E B7        	ORA	A	;TEST FOR TABLE END
 F14F C8        	RZ		;NOT FOUND POST THAT AND RETURN
 F150 E5        	PUSH	H	;SAVE START OF SCAN ADDRESS
 F151 BE        	CMP	M	;TEST FIRST CHR
 F152 13        	INX	D
 F153 C25FF1    	JNZ	NCOM
                ;
 F156 23        	INX	H
 F157 1A        	LDAX	D
 F158 BE        	CMP	M	;NOW SECOND CHARACTER
 F159 C25FF1    	JNZ	NCOM	;GOODNESS
                ;
 F15C E1        	POP	H	;RETURN HL TO PT TO CHAR START
 F15D B7        	ORA	A	;FORCE TO NON-ZERO FLAG
 F15E C9        	RET		;LET CALLER KNOW
                ;
                ;
 F15F 13        NCOM:	INX	D	;GO TO NEXT ENTRY
 F160 13        	INX	D
 F161 13        	INX	D
 F162 E1        	POP	H	;GET BACK ORIGINAL ADDRESS
 F163 C34DF1    	JMP	FDCOM	;CONTINUE SEARCH
                ;
                ;
                ; SET UP TO PROCESS AN INPUT LINE
 F166 =         STUP:	EQU	$	;PREPARE WHETHER VDM OR NOT
 F166 215FBE    	LXI	H,INLIN	;ASSUME NON-VDM INPUT
 F169 2208BC    	SHLD	INPTR	;ALSO RESET PTR FOR NOW
 F16C C9        	RET
                ;
                ;           COMMAND TABLE
                ;
                ;  THIS TABLE DESCRIBES THE VALID COMMANDS FOR CUTER
                ;
 F16D =         COMTAB:	EQU	$	;START OF KNOWN COMMANDS
 F16D 4455      	DW	'DU'	;DUMP
 F16F 46F2      	DW	DUMP
 F171 454E      	DW	'EN'	;ENTR
 F173 ADF2      	DW	ENTER
 F175 4558      	DW	'EX'	;EXEC
 F177 E2F2      	DW	EXEC
 F179 4745      	DW	'GE'	;GET
 F17B 2AF3      	DW	TLOAD
 F17D 5341      	DW	'SA'	;SAVE
 F17F 69F3      	DW	TSAVE
 F181 4847      	DW	'HG'	;HEX FILE GET
 F183 64F6      	DW	HXGET
 F185 4853      	DW	'HS'	;HEX FILE SAVE
 F187 F2F6      	DW	HXSAVE
 F189 5845      	DW	'XE'	;XEQ
 F18B 29F3      	DW	TXEQ
 F18D 4341      	DW	'CA'	;CAT
 F18F B0F3      	DW	TLIST
 F191 5345      	DW	'SE'	;SET COMMAND
 F193 F9F3      	DW	CSET
 F195 4355      	DW	'CU'	;CUSTOM COMMAND ENTER/CLEAR
 F197 2FF4      	DW	CUSET
 F199 00        	DB	0	;END OF TABLE MARK
                
                ;
                ;   OUTPUT DEVICE TABLE
                ;
 F19A 76F0      OTAB:	DW	VDM01	;VDM DRIVER
 F19C 45F0      	DW	SEROT	;SERIAL OUTPUT
 F19E 58F0      	DW	PAROT	;PARALLEL OUTPUT
 F1A0 6AF0      	DW	ERROT	;ERROR OR USER DRIVER HANDLER
                ;
                ;    INPUT DEVICE TABLE
                ;
 F1A2 35F0      ITAB:	DW	KREA1	;KEYBOARD INPUT
 F1A4 3DF0      	DW	SREA1	;SERIAL INPUT
 F1A6 50F0      	DW	PARIT	;PARALLEL INPUT
 F1A8 63F0      	DW	ERRIT	;ERROR OR USER DRIVER HANDLER
                ;
                ;
                ;       SECONDARY COMMAND TABLE FOR SET COMMAND
                ;
 F1AA 5441      SETAB:	DW	'TA'	;SET TAPE SPEED
 F1AC 0DF4      	DW	TASPD
 F1AE 533D      	DW	'S='	;SET DISPLAY SPEED
 F1B0 0EF4      	DW	DISPD
 F1B2 493D      	DW	'I='	;SET INPUT PORT
 F1B4 0FF4      	DW	SETIN
 F1B6 4F3D      	DW	'O='	;SET OUTPUT PORT
 F1B8 13F4      	DW	SETOT
 F1BA 4349      	DW	'CI'	;SET CUSTOM DRIVER ADDRESS
 F1BC 17F4      	DW	SETCI
 F1BE 434F      	DW	'CO'	;SET CUSTOM OUTPUT DRIVER ADDRESS
 F1C0 1BF4      	DW	SETCO
 F1C2 5845      	DW	'XE'	;SET HEADER XEQ ADDRESS
 F1C4 23F4      	DW	SETXQ
 F1C6 5459      	DW	'TY'	;SET HEADER TYPE
 F1C8 1FF4      	DW	SETTY
 F1CA 4E3D      	DW	'N='	;SET NUMBER OF NULLS
 F1CC 27F4      	DW	SETNU
 F1CE 4352      	DW	'CR'	;SET CRC (NORMAL OR IGNORE CRC ERRORS)
 F1D0 2BF4      	DW	SETCR
 F1D2 00        	DB	0	;END OF TABLE MARK
                ; -*-
                ;
                ;
                ;      OUTPUT A CRLF FOLLOWED BY A PROMPT
                ;
 F1D3 CDDBF1    PROMPT:	CALL	CRLF
 F1D6 063E      	MVI	B,'>'	;THE PROMPT
 F1D8 C319F0    	JMP	SOUT	;PUT IT ON THE SCREEN
                ;
 F1DB 060D      CRLF:	MVI	B,CR	;CARRIAGE RETURN
 F1DD CD19F0    	CALL	SOUT
 F1E0 060A      	MVI	B,LF	;LINE FEED
 F1E2 CD19F0    	CALL	SOUT
 F1E5 3A0ABC    	LDA	NUCNT	;GET COUNT OF NULLS TO OUTPUT
 F1E8 4F        	MOV	C,A	;SAVE COUNT IN C
 F1E9 0D        NULOT:	DCR	C
 F1EA F8        	RM		;COUNTED DOWN PAST ZERO (MAX COUNT IS X'7F')
 F1EB AF        	XRA	A	;HERE IS THE NULL
 F1EC CDA9F2    	CALL	OUTH	;OUTPUT IT
 F1EF C3E9F1    	JMP	NULOT	;LOOP FOR NUMBER OF NULLS
                ;
                ;
                ;  SCAN OVER UP TO 12 CHARACTERS LOOKING FOR A BLANK
                ;
 F1F2 0E0C      SBLK:	MVI	C,12	;MAXIMUM COMMAND STRING
 F1F4 1A        SBLK1:	LDAX	D
 F1F5 FE20      	CPI	' '
 F1F7 CA05F2    	JZ	SCHR	;GOT A BLANK NOW SCAN PAST IT
 F1FA 13        	INX	D
 F1FB FE3D      	CPI	'='	;A EQUAL WILL ALSO STOP US (AT NEXT CHAR)
 F1FD CA05F2    	JZ	SCHR	;FOUND, DE PT TO NEXT CHAR
 F200 0D        	DCR	C	;NO MORE THAN TWELVE
 F201 C2F4F1    	JNZ	SBLK1
 F204 C9        	RET		;GO BACK WITH ZERO FLAG SET
                ;
                ;
                ;  SCAN PAST UP TO 10 BLANK POSITIONS LOOKING FOR
                ; A NON BLANK CHARACTER.
                ;
 F205 0E0A      SCHR:	MVI	C,10	;SCAN TO FIRST NON BLANK CHR WITHIN 10
 F207 1A        SCHR1:	LDAX	D	;GET NEXT CHARACTER
 F208 FE20      	CPI	' '
 F20A C0        	RNZ		;WE'RE PAST THEM
 F20B 13        	INX	D	;NEXT SCAN ADDRESS
 F20C 0D        	DCR	C
 F20D C8        	RZ		;COMMAND ERROR
 F20E C307F2    	JMP	SCHR1	;KEEP LOOPING
                ;
                ;  THIS ROUTINE SCANS OVER CHARACTERS, PAST BLANKS AND
                ; CONVERTS THE FOLLOWING ADDRESS TO HEX.  ERRORS RETURN TO
                ; THE ERROR HANDLER.
                ;
 F211 CDF2F1    SCONV:	CALL	SBLK
 F214 CA04F3    	JZ	ERR1
                ;
                ;  THIS ROUTINE CONVERTS ASCII DIGITS INTO BINARY FOLLOWING
                ; A STANDARD HEX CONVERSION.  THE SCAN STOPS WHEN AN ASCII
                ; SPACE IS ENCOUNTERED.  PARAMETER ERRORS REPLACE THE ERROR
                ; CHARACTER ON THE SCREEN WITH A QUESTION MARK.
                ;
 F217 210000    SHEX:	LXI	H,0	;CLEAR H & L
 F21A 1A        SHE1:	LDAX	D	;GET CHARACTER
 F21B FE20      	CPI	20H	;IS IT A SPACE?
 F21D C8        	RZ		;IF SO
 F21E FE2F      	CPI	'/'
 F220 C8        	RZ
 F221 FE3A      	CPI	':'
 F223 C8        	RZ
                ;
 F224 29        HCONV:	DAD	H	;MAKE ROOM FOR THE NEW ONE
 F225 29        	DAD	H
 F226 29        	DAD	H
 F227 29        	DAD	H
 F228 CD34F2    	CALL	HCOV1	;DO THE CONVERSION
 F22B D204F3    	JNC	ERR1	;NOT VALID HEXIDECIMAL VALUE
 F22E 85        	ADD	L
 F22F 6F        	MOV	L,A	;MOVE IT IN
 F230 13        	INX	D	;BUMP THE POINTER
 F231 C31AF2    	JMP	SHE1
                ;
 F234 D630      HCOV1:	SUI	48	;REMOVE ASCII BIAS
 F236 FE0A      	CPI	10
 F238 D8        	RC		;IF LESS THAN 9
 F239 D607      	SUI	7	;IT'S A LETTER??
 F23B FE10      	CPI	10H
 F23D C9        	RET		;WITH TEST IN HAND
                ;
                ;
                ;  THIS ROUTINE WILL SEE IF A FIELD (OPERAND) IS PRESENT.
                ;  IF NOT, THEN HL WILL REMAIN AS THEY WERE ON ENTRY.
                ;  IF IT WAS PRESENT, THEN HL=THAT VALUE IN HEX.
                ;
 F23E =         PSCAN:	EQU	$	;OPTIONAL FIELD SCANNER
 F23E CDF2F1    	CALL	SBLK	;SEE IF FIELD IS PRESENT
 F241 C8        	RZ		;RETURN LEAVING HL AS THEY WERE ON ENTRY
 F242 CD17F2    	CALL	SHEX	;FIELD IS THERE, GO GET IT
 F245 C9        	RET		;HL= EITHER OPTIONAL FIELD (HEX), OR AS IT WAS
                ;
                ;
                ;
                ;
                ;           DUMP COMMAND
                ;
                ;     THIS ROUTINE DUMPS CHARACTERS FROM MEMORY TO THE
                ;  CURRENT OUTPUT DEVICE.
                ;  ALL VALUES ARE DESPLAYED AS ASCII HEX.
                ;
                ;  THE COMMAND FORM IS AS FOLLOWS:
                ;
                ;        DUMP  ADDR1  ADDR2
                ;
                ;    THE VALUES FROM ADDR1 TO ADDR2 ARE THEN OUTPUT TO THE
                ;  OUTPUT DEVICE.  IF ONLY ADDR1 IS SPECIFIED THEN THE
                ;  VALUE AT THAT ADDRESS IS OUTPUT.
                ;
                ;  IF WHILE DUMPING, THE MODE KEY IS PRESSED, THE DUMP WILL
                ;  BE TERMINATED.  IF THE SPACE BAR IS PRESSED, THE DUMP
                ;  WILL BE TEMPORARILY SUSPENDED UNTIL ANY KEY IS PRESSED.
                ;
 F246 =         DUMP:	EQU	$	;SET UP REGS TO DUMP SPECIFIED AREA
 F246 CD11F2    	CALL	SCONV	;GET START ADDR (REQUIRED)
 F249 E5        	PUSH	H	;SAVE THE START ADDR
 F24A CD3EF2    	CALL	PSCAN	;GET OPTIONAL END ADDR, HL=THIS OR START ADDR
 F24D D1        	POP	D	;DE=START ADDR
 F24E EB        	XCHG		;DE=END ADDR, HL=START ADDR NOW
                ;
 F24F CDDBF1    DLOOP:	CALL	CRLF
 F252 CD72F2    	CALL	ADOUT	;OUTPUT ADDRESS
 F255 CD90F2    	CALL	BOUT	;ANOTHER SPACE TO KEEP IT PRETTY
 F258 0E10      	MVI	C,16	;VALUES PER LINE
                ;
 F25A 7E        DLP1:	MOV	A,M	;GET THE CHR
 F25B C5        	PUSH	B	;SAVE VALUE COUNT
 F25C CD77F2    	CALL	HBOUT	;SEND IT OUT WITH A BLANK
 F25F 7C        	MOV	A,H	;CRNT ADDR
 F260 BA        	CMP	D	;VERSUS ENDING ADDR
 F261 DA69F2    	JC	DLP1A	;NOT DONE YET
 F264 7D        	MOV	A,L	;TRY LOW ORDER BYTE
 F265 BB        	CMP	E
 F266 D2C3F0    	JNC	COMND	;ALL DONE WHEN CRNT REACHES ENDING
 F269 =         DLP1A:	EQU	$	;HERE TO KEEP DUMPING
 F269 C1        	POP	B	;VALUES PER LINE
 F26A 23        	INX	H
 F26B 0D        	DCR	C	;BUMP THE LINE COUNT
 F26C C25AF2    	JNZ	DLP1	;NOT ZERO IF MORE FOR THIS LINE
 F26F C34FF2    	JMP	DLOOP	;DO A LFCR BEFORE THE NEXT
                ;
                ;    OUTPUT HL AS HEX 16 BIT VALUE
                ;
 F272 7C        ADOUT:	MOV	A,H	;H FIRST
 F273 CD95F2    	CALL	HEOUT
 F276 7D        	MOV	A,L	;THEN L FOLLOWED BY A SPACE
                ;
 F277 CD95F2    HBOUT:	CALL	HEOUT
 F27A CD1FF0    	CALL	SINP	;SEE IF WE SHD ESCAPE FM DUMP
 F27D CA90F2    	JZ	BOUT	;NO--ADD THE SPACE THEN
 F280 E67F      	ANI	7FH	;MAKE SURE ITS CLEAR OF PARITY
 F282 CAC3F0    	JZ	COMND	;EITHER MODE (OR CTL-@)
 F285 FE20      	CPI	' '	;IS IT SPACE
 F287 C290F2    	JNZ	BOUT	;NO--IGNORE THE CHAR
 F28A CD1FF0    WTLP1:	CALL	SINP	;ON SPACE, WAIT FOR ANY OTHER CHAR
 F28D CA8AF2    	JZ	WTLP1	;JUST LOOP AFTER A SPACE UNTIL ANY KEY PRESSED
 F290 0620      BOUT:	MVI	B,' '
 F292 C319F0    	JMP	SOUT	;PUT IT OUT
                ;
 F295 4F        HEOUT:	MOV	C,A	;GET THE CHARACTER
 F296 0F        	RRC
 F297 0F        	RRC		;MOVE THE HIGH FOUR DOWN
 F298 0F        	RRC
 F299 0F        	RRC
 F29A CD9EF2    	CALL	HEOU1	;PUT THEM OUT
 F29D 79        	MOV	A,C	;THIS TIME THE LOW FOUR
                ;
 F29E E60F      HEOU1:	ANI	0FH	;FOUR ON THE FLOOR
 F2A0 C630      	ADI	48	;WE WORK WITH ASCII HERE
 F2A2 FE3A      	CPI	58	;0-9?
 F2A4 DAA9F2    	JC	OUTH	;YUP!
 F2A7 C607      	ADI	7	;MAKE IT A LETTER
 F2A9 47        OUTH:	MOV	B,A	;OUTPUT IT FROM REGISTER 'B'
 F2AA C319F0    	JMP	SOUT
                ;
                ;
                ;           ENTR COMMAND
                ;
                ;   THIS ROUTINE GETS VALUES FROM THE KEYBOARD AND ENTERS
                ; THEM INTO MEMORY.  THE INPUT VALUES ARE SCANNED FOLLOWING
                ; A STANDARD 'GCLIN' INPUT SO ON-SCREEN EDITING MAY TAKE
                ; PLACE PRIOR TO THE LINE TERMINATOR.  A SLASH '/'
                ; ENDS THE ROUTINE AND RETURNS CONTROL TO THE COMMAND MODE.
                ;
 F2AD CD11F2    ENTER:	CALL	SCONV	;SCAN OVER CHARS AND GET ADDRESS
 F2B0 E5        	PUSH	H	;SAVE ADDRESS
                ;
 F2B1 CDDBF1    ENLOP:	CALL	CRLF
 F2B4 063A      	MVI	B,':'
 F2B6 CD19F0    	CALL	SOUT	;DSPLY THE COLON
 F2B9 CDD2F0    	CALL	GCLI0	;INIT AND PROCESS A LINE
 F2BC CD66F1    	CALL	STUP	;SET UP TO PROCESS INPUT LINE
 F2BF EB        	XCHG		;....TO DE
                ;
                ;
 F2C0 0E03      ENLO1:	MVI	C,3	;NO MORE THAN THREE SPACES BETWEEN VALUES
 F2C2 CD07F2    	CALL	SCHR1	;SCAN TO NEXT VALUE
 F2C5 CAB1F2    	JZ	ENLOP	;LAST ENTRY FOUND START NEW LINE
                ;
 F2C8 FE2F      	CPI	'/'	;COMMAND TERMINATOR?
 F2CA CAC3F0    	JZ	COMND	;IF SO...
 F2CD CD17F2    	CALL	SHEX	;CONVERT VALUE
 F2D0 FE3A      	CPI	':'	;ADDRESS TERMINATOR?
 F2D2 CADDF2    	JZ	ENLO3	;GO PROCESS IF SO
 F2D5 7D        	MOV	A,L	;GET LOW PART AS CONVERTED
 F2D6 E1        	POP	H	;GET MEMORY ADDRESS
 F2D7 77        	MOV	M,A	;PUT IN THE VALUE
 F2D8 23        	INX	H
 F2D9 E5        	PUSH	H	;BACK GOES THE ADDRESS
 F2DA C3C0F2    	JMP	ENLO1	;CONTINUE THE SCAN
                ;
 F2DD E3        ENLO3:	XTHL		;PUT NEW ADDRESS ON STACK
 F2DE 13        	INX	D	;MOVE SCAN PAST TERMINATOR
 F2DF C3C0F2    	JMP	ENLO1
                ;
                ;
                ;              EXECUTE COMMAND
                ;
                ;   THIS ROUTINE GETS THE FOLLOWING PARAMETER AND DOES A
                ; PROGRAM JUMP TO THE LOCATION GIVEN BY IT.  IF PROPER
                ; STACK OPERATIONS ARE USED WITHIN THE EXTERNAL PROGRAM
                ; IT CAN DO A STANDARD 'RET'URN TO THE CUTER COMMAND MODE.
                ;
                ;
 F2E2 CD11F2    EXEC:	CALL	SCONV	;SCAN PAST BLANKS AND GET PARAMETER
 F2E5 =         EXEC1:	EQU	$	;HERE TO GO TO HL
 F2E5 E5        	PUSH	H	;SAVE ON STACK
 F2E6 2100F0    	LXI	H,START	;LET USER KNOW WHERE WE ARE
 F2E9 C9        	RET		;AND OFF TO USER
                ;
                ;
                ;
                ;
                ;   THIS ROUTINE GETS A NAME OF UP TO 5 CHARACTERS
                ;  FROM THE INPUT STRING.  IF THE TERMINATOR IS A
                ;  SLASH (/) THEN THE CHARACTER FOLLOWING IS TAKEN
                ;  AS THE CASSETTE UNIT SPECIFICATION.
                ;
                ;
 F2EA =         NAME0:	EQU	$	;ENTER HERE TO SET HL TO THEAD
 F2EA 2117BC    	LXI	H,THEAD	;PT WHERE TO PUT NAME
 F2ED CDF2F1    NAME:	CALL	SBLK	;SCAN OVER TO FIRST CHRS
 F2F0 0606      	MVI	B,6
                ;
 F2F2 1A        NAME1:	LDAX	D	;GET CHARACTER
 F2F3 FE20      	CPI	' '	;NO UNIT DELIMITER
 F2F5 CA10F3    	JZ	NFIL
 F2F8 FE2F      	CPI	'/'	;UNIT DELIMITER
 F2FA CA10F3    	JZ	NFIL
 F2FD 77        	MOV	M,A
 F2FE 13        	INX	D	;BUMP THE SCAN POINTER
 F2FF 23        	INX	H
 F300 05        	DCR	B
 F301 C2F2F2    	JNZ	NAME1	;NAME IS OK, FALL THRU TO 'ERR1' IF NOT
                ;
                ;     CUTER ERROR HANDLER
                ;
 F304 EB        ERR1:	XCHG		;GET SCAN ADDRESS
 F305 CDDBF1    ERR2:	CALL	CRLF
 F308 063F      	MVI	B,'?'	;SET UP THE ????
 F30A CD19F0    	CALL	SOUT	;INDICATE INPUT NOT VALID
 F30D C3C3F0    	JMP	COMND	;NOW READY FOR NEXT INPUT
                ;
                ;
                ;
                ;  HERE WE HAVE SCANNED OFF THE NAME. ZERO FILL IN FOR
                ;  NAMES LESS THAN FIVE CHARACTERS.
                ;
 F310 3600      NFIL:	MVI	M,0	;PUT IN AT LEAST ONE ZERO
 F312 23        	INX	H
 F313 05        	DCR	B
 F314 C210F3    	JNZ	NFIL	;LOOP UNTIL B IS ZERO
                ;
 F317 FE2F      	CPI	'/'	;IS THERE A UNIT SPECIFICATION?
 F319 3E01      	MVI	A,1	;PRETEND NOT
 F31B C224F3    	JNZ	DEFLT
 F31E 13        	INX	D	;MOVE PAST THE TERMINATOR
 F31F CD05F2    	CALL	SCHR	;GO GET IT
 F322 D630      	SUI	'0'	;REMOVE ASCII BIAS
                ;
 F324 =         DEFLT:	EQU	$	;CNVRT TO INTERNAL BIT FOR TAPE CONTROL
 F324 AF        	XRA	A	;JUST RETURN ZERO FOR ACR
 F325 324FBC    STUNT:	STA	FNUMF	;SET IT IN
 F328 C9        	RET
                ;
                ;
                ;
                ;   THIS ROUTINE PROCESSES THE XEQ AND GET COMMANDS
                ;
                ;
 F329 3E        TXEQ:	DB	3EH	;THIS BEGINS "MVI" OF THE "XRA" FOLLOWING
 F32A AF        TLOAD:	XRA	A	;A=0 TLOAD, A=AF (#0) THEN XEQ
 F32B F5        	PUSH	PSW	;SAVE FLAG TO SAY WHETHER LOAD OR XEQ
 F32C 2127BC    	LXI	H,DHEAD	;PLACE DUMMY HDR HERE FOR COMPARES
 F32F CDEDF2    	CALL	NAME	;SET IN NAME AND UNIT
 F332 210000    	LXI	H,0	;ASSUME LOAD ADDR NOT GIVEN
 F335 CD3EF2    	CALL	PSCAN	;HL EITHER =0, OR OVERRIDE LOAD ADDR
                ;
 F338 EB        TLOA2:	XCHG		;PUT ADDRESS IN DE
 F339 2127BC    	LXI	H,DHEAD	;PT TO NORMAL HDR
 F33C 7E        	MOV	A,M	;GET 1ST CHAR OF NAME
 F33D B7        	ORA	A	;IS THERE A NAME?
 F33E C244F3    	JNZ	TLOA3	;YES--LOOK FOR IT
 F341 2117BC    	LXI	H,THEAD	;PT TO SAME HDR TO LOAD NEXT FILE
 F344 E5        TLOA3:	PUSH	H	;SAVE PTR TO WHICH HDR TO USE
 F345 CDCDF3    	CALL	ALOAD	;GET UNIT AND SPEED
 F348 E1        	POP	H	;RESTORE PTR TO PROPER HDR TO USE
 F349 CD3DF5    	CALL	RTAPE	;READ IN THE TAPE
 F34C DA99F3    	JC	TAERR	;TAPE ERROR?
                ;
 F34F CDCFF3    	CALL	NAOUT	;PUT OUT THE HEADER PARAMETERS
 F352 F1        	POP	PSW	;RESTORE FLAG SAYING WHETHER IT WAS LOAD OR XEQ
 F353 B7        	ORA	A
 F354 C8        	RZ		;AUTO XEQ NOT WANTED
 F355 3A1DBC    	LDA	HTYPE	;CHECK TYPE
 F358 B7        	ORA	A	;SET FLAGS
 F359 FA99F3    	JM	TAERR	;TYPE IS NON XEQ
 F35C 3A1CBC    	LDA	THEAD+5
 F35F B7        	ORA	A
 F360 C299F3    	JNZ	TAERR	;THE BYTE MUST BE ZERO FOR AUTO XEQ
 F363 2A22BC    	LHLD	XEQAD	;GET THE TAPE ADDRESS
 F366 C3E5F2    	JMP	EXEC1	;AND GO OFF TO IT
                ;
                ;
                ;
                ;   THIS ROUTINE IS USED TO SAVE PROGRAMS AND DATA ON
                ;   THE CASSETTE UNIT.
                ;
                ;
 F369 =         TSAVE:	EQU	$	;SAVE MEMORY IMAGE TO TAPE
 F369 CDEAF2    	CALL	NAME0	;GET NAME AND UNIT
 F36C CD11F2    	CALL	SCONV	;GET START ADDRESS
 F36F E5        	PUSH	H	;SAVE START ADDR FOR SIZE COMPUTATION LATER
 F370 CD11F2    	CALL	SCONV	;GET END ADDR (REQUIRED)
 F373 E3        	XTHL		;HL=START ADDR NOW, STACK=END ADDR
 F374 E5        	PUSH	H	;STACK =START FOLLOWED BY END
 F375 CD3EF2    	CALL	PSCAN	;SEE IF RETRIEVE FROM ADDR
 F378 2220BC    	SHLD	LOADR	;EITHER ACTUAL START, OR OVERRIDE INTO HDR
 F37B E1        	POP	H	;;HL=START ADDR
 F37C D1        	POP	D	;DE=END ADDR
 F37D E5        	PUSH	H	;PUT START BACK ONTO STACK
 F37E 7B        	MOV	A,E	;SIZE=END-START+1
 F37F 95        	SUB	L
 F380 6F        	MOV	L,A
 F381 7A        	MOV	A,D
 F382 DE00      	SBI	0	;THIS EQUALS A "SBB H"
 F384 94        	SUB	H	;THIS IS NEEDED
 F385 67        	MOV	H,A
 F386 23        	INX	H
 F387 221EBC    	SHLD	BLOCK	;STORE THE SIZE
 F38A E5        	PUSH	H	;SAVE AS THE BLOCK SIZE
                ;
 F38B CDCDF3    	CALL	ALOAD	;GET UNIT AND SPEED
 F38E 2117BC    	LXI	H,THEAD	;PT TO HEADER TO WRITE
 F391 CD23F6    	CALL	WHEAD	;TURN TAPE ON, THEN WRITE HEADER
 F394 D1        	POP	D	;GET BACK THE SIZE
 F395 E1        	POP	H	;AND GET BACK THE ACTUAL START ADDR
 F396 C303F6    	JMP	WTAP1	;WRITE THE BLK (W/EXTRA PUSH)
                ;
                ;   OUTPUT ERROR AND HEADER
                ;
 F399 CDDBF1    TAERR:	CALL	CRLF
 F39C 1606      	MVI	D,6
 F39E 21AAF3    	LXI	H,ERRM
 F3A1 CDE9F3    	CALL	NLOOP	;OUTPUT ERROR
 F3A4 CDCFF3    	CALL	NAOUT	;THEN THE HEADER
 F3A7 C3C3F0    	JMP	COMN1
                ;
 F3AA 4552524F52ERRM:	DB	'ERROR '
                
                ;
                ;
                ;              CAT COMMAND
                ;
                ;   THIS ROUTINE READS HEADERS FROM THE TAPE AND OUTPUTS
                ;   THEM TO THE OUTPUT DEVICE.  IT CONTINUES UNTIL THE
                ;   MODE KEY IS DEPRESSED.
                ;
 F3B0 =         TLIST:	EQU	$	;PRODUCE A LIST OF FILES ON A TAPE
 F3B0 CDEAF2    	CALL	NAME0	;GET UNIT IF ANY (NAME IS IGNORED)
 F3B3 CDDBF1    	CALL	CRLF	;START ON A FRESH LINE
                ;
                ;
 F3B6 CDCDF3    LLIST:	CALL	ALOAD
 F3B9 0601      	MVI	B,1
 F3BB CD56F6    	CALL	TON	;TURN ON THE TAPE
 F3BE CD95F5    LIST1:	CALL	RHEAD
 F3C1 DAC3F0    	JC	COMN1	;TRUN OFF THE TAPE UNIT
 F3C4 C2BEF3    	JNZ	LIST1
 F3C7 CDCFF3    	CALL	NAOUT	;OUTPUT THE HEADER
 F3CA C3B6F3    	JMP	LLIST
                ;
                ;
                ;   THIS ROUTINE GETS THE CASSETTE UNIT NUMBER AND
                ;   SPEED TO REGISTER "A" FOR THE TAPE CALLS
                ;
 F3CD AF        ALOAD:	XRA	A	;JUST RETURN ZERO FOR ACR
 F3CE C9        	RET		;AND GO BACK
                ;
                ;   THIS ROUTINE OUTPUTS THE NAME AND PARAMETERS OF
                ;   THEAD TO THE OUTPUT DEVICE.
                ;
                ;
 F3CF 1608      NAOUT:	MVI	D,8
 F3D1 2116BC    	LXI	H,THEAD-1  ;POINT TO THE HEADER
 F3D4 CDE9F3    	CALL	NLOOP	;OUTPUT THE HEADER
 F3D7 CD90F2    	CALL	BOUT	;ANOTHER BLANK
 F3DA 2A20BC    	LHLD	LOADR	;NOW THE LOAD ADDRESS
 F3DD CD72F2    	CALL	ADOUT	;PUT IT OUT
 F3E0 2A1EBC    	LHLD	BLOCK	;AND THE BLOCK SIZE
 F3E3 CD72F2    	CALL	ADOUT
 F3E6 C3DBF1    	JMP	CRLF	;DO THE CRLF AND RETURN
                ;
                ;
 F3E9 7E        NLOOP:	MOV	A,M	;GET CHARACTER
 F3EA B7        	ORA	A
 F3EB C2F0F3    	JNZ	CHRLI	;IF IT ISN'T A ZERO
 F3EE 3E20      	MVI	A,' '	;SPACE OTHERWISE
 F3F0 =         CHRLI:	EQU	$	;CHAR IS OK TO SEND
 F3F0 CDA9F2    	CALL	OUTH	;OUTPUT IT FROM A REG
 F3F3 23        	INX	H
 F3F4 15        	DCR	D
 F3F5 C2E9F3    	JNZ	NLOOP
 F3F8 C9        	RET
                ;
                ;
                ;
                ;
                ;      "SET" COMMAND
                ;
                ;   THIS ROUTINE GETS THE ASSOCIATED PARAMETER AND
                ;   DISPATCHES TO THE PROPER ROUTINE FOR SETTING
                ;   MEMORY VALUES.
                ;
 F3F9 CDF2F1    CSET:	CALL	SBLK	;SCAN TO SECONDARY COMMAND
 F3FC CA04F3    	JZ	ERR1	;MUST HAVE AT LEAST SOMETHING!!
 F3FF D5        	PUSH	D	;SAVE SCAN ADDRESS
 F400 CD11F2    	CALL	SCONV	;CONVERT FOLLOWING VALUE
 F403 E3        	XTHL		;HL=SAVED SCAN ADDR AND STACK=VALUE
 F404 11AAF1    	LXI	D,SETAB	;SECONDARY COMMAND TABLE
 F407 CD4DF1    	CALL	FDCOM	;TRY TO LOCATE IT
 F40A C33EF1    	JMP	DISP0	;OFF TO IT OR ERROR IF NOT IN TBL
                ;
                ;
                ;  THIS ROUTINE SETS THE TAPE SPEED
                ;
 F40D =         TASPD:	EQU	$	;GET CONVERTED VALUE
 F40D C9        	RET		;DO NOTHING FOR ACR
                ;
                ;
 F40E =         STSPD:	EQU	$	;VDM ESCAPE SEQUENCE COMES HERE
 F40E =         DISPD:	EQU	$	;SET DISPLAY SPEED
 F40E C9        	RET		;DO NOTHING FOR ACR
                ;
                ;
 F40F =         SETIN:	EQU	$	;SET AN INPUT PSUEDO PORT
 F40F 3206BC    	STA	IPORT
 F412 C9        	RET
                ;
                ;
 F413 =         SETOT:	EQU	$	;SET AN OUTPUT PSUEDO PORT
 F413 3207BC    	STA	OPORT
 F416 C9        	RET
                ;
                ;
 F417 =         SETCI:	EQU	$	;DEFINE USER INPUT RTN ADDR
 F417 2200BC    	SHLD	UIPRT
 F41A C9        	RET
                ;
                ;
 F41B =         SETCO:	EQU	$	;DEFINE USER OUTPUT RTN ADDR
 F41B 2202BC    	SHLD	UOPRT
 F41E C9        	RET
                ;
                ;
 F41F =         SETTY:	EQU	$	;SET TAPE HDR TYPE
 F41F 321DBC    	STA	HTYPE
 F422 C9        	RET
                ;
                ;
 F423 =         SETXQ:	EQU	$	;SET TAPE-EXECUTE ADDDR FOR HDR
 F423 2222BC    	SHLD	XEQAD
 F426 C9        	RET
                ;
                ;
 F427 =         SETNU:	EQU	$	;HERE TO SET NUMBER OF NULLS
 F427 320ABC    	STA	NUCNT	;THIS IS IT
 F42A C9        	RET
                ;
                ;
 F42B =         SETCR:	EQU	$	;SET CRC TO BE NORMAL, OR IGNORE CRC ERRORS
 F42B 320BBC    	STA	IGNCR	;FF=IGNORE CRC ERRORS, ELSE=NORMAL
 F42E C9        	RET
                ;
                ;
 F42F =         CUSET:	EQU	$	;TRY TO SET/CLEAR CUSTOM ROUTINE ADDR
 F42F CDEAF2    	CALL	NAME0	;GET A NAME (S/B 2 CHARS OR MORE)
 F432 21C3F0    	LXI	H,COMND	;PT HERE IN CASE ADDR NOT GIVEN
 F435 CD3EF2    	CALL	PSCAN	;GET OPTIONAL OPERAND IF ANY
 F438 E5        	PUSH	H	;SAVE THAT VALUE (IF ANY)
 F439 2117BC    	LXI	H,THEAD	;PT TO NAME
 F43C CD4AF1    	CALL	FDCOU	;SEE IF NAME IS KNOWN IN CUST TABLE
 F43F CA45F4    	JZ	CUSE2	;NO--PROCEED TO KNOW IT
 F442 1B        	DCX	D	;DE PT TO 1ST CHAR OF NAME IN TBL
 F443 3600      	MVI	M,0	;(HL CAME BACK PT'ING TO THEAD)  CLR THIS NAME
 F445 =         CUSE2:	EQU	$	;ENTER NEW ONE IN TBL
 F445 7E        	MOV	A,M	;GET 1ST CHAR OF NAME
 F446 12        	STAX	D	;PUT NAME INTO TABLE
 F447 13        	INX	D
 F448 23        	INX	H
 F449 7E        	MOV	A,M	;GET 2ND CHAR OF NAME
 F44A 12        	STAX	D	;NAME IS NOW POSTED
 F44B 13        	INX	D	;PT TO 1ST BYTE OF ADDR
 F44C E1        	POP	H	;RESTORE SAVED RTN ADDR
 F44D EB        	XCHG		;DE=RTN ADDR, HL=THIS CU ENTRY
 F44E 73        	MOV	M,E	;LO BYTE
 F44F 23        	INX	H
 F450 72        	MOV	M,D	;AND HI BYTE
 F451 C9        	RET		;ALL DONE
                ;
                ;
                ; -*-
                ;
                ;
                ;
                ;
                ;   THE FOLLOWING ROUTINES PROVIDE "BYTE BY BYTE" ACCESS
                ;  TO THE CASSETTE TAPES ON EITHER A READ OR WRITE BASIS.
                ;
                ;  THE TAPE IS READ ONE BLOCK AT A TIME AND INDIVIDUAL
                ;  TRANSFERS OF DATA HANDLED BY MANAGING A BUFFER AREA.
                ;
                ;  THE BUFFER AREA IS CONTROLLED BY A FILE CONTROL BLOCK
                ;  (FCB) WHOSE STRUCTURE IS:
                ;
                ;
                ;     7 BYTES FOR EACH OF THE TWO FILES STRUCTURED AS
                ;   FOLLOWS:
                ;
                ;         1 BYTE -  ACCESS CONTROL   00 IF CLOSED
                ;                                    FF IF READING
                ;                                    FE IF WRITING
                ;         1 BYTE -  READ COUNTER
                ;         1 BYTE -  BUFFER POSITION POINTER
                ;         2 BYTE -  CONTROL HEADER ADDRESS
                ;         2 BYTE -  BUFFER LOCATION ADDRESS
                ;
                ;
                ;
                ;        THIS ROUTINE "OPENS" THE CASSETTE UNIT FOR ACCESS
                ;
                ;   ON ENTRY:  A - HAS THE TAPE UNIT NUMBER (1 OR 2)
                ;             HL - HAS USER SUPPLIED HEADER FOR TAPE FILE
                ;
                ;
                ;   NORMAL RETURN:   ALL REGISTERS ARE ALTERED
                ;                    BLOCK IS READY FOR ACCESS
                ;
                ;   ERROR RETURN:    CARRY BIT IS SET
                ;
                ;   ERRORS:  BLOCK ALREADY OPEN
                ;
                ;
 F452 E5        BOPEN:	PUSH	H	;SAVE HEADER ADDRESS
 F453 CDA5F4    	CALL	LFCB	;GET ADDRESS OF FILE CONTROL
 F456 C26CF4    	JNZ	TERE2	;FILE WAS ALREADY OPEN
 F459 3601      	MVI	M,1	;NOW IT IS
 F45B 23        	INX	H	;POINT TO READ COUNT
 F45C 77        	MOV	M,A	;ZERO
 F45D 23        	INX	H	;POINT TO BUFFER CURSOR
 F45E 77        	MOV	M,A	;PUT IN THE ZERO COUNT
                ;
                ;  ALLOCATE THE BUFFER
                ;
 F45F 115EBC    	LXI	D,FBUF1	;POINT TO BUFFER AREA
 F462 3A4FBC    	LDA	FNUMF	;GET WHICH ONE WE ARE GOING TO USE
 F465 82        	ADD	D
 F466 57        	MOV	D,A	;256 BIT ADD
                ;
 F467 C1        UBUF:	POP	B	;HEADER ADDRESS
 F468 B7        	ORA	A	;CLEAR CARRY AND RETURN AFTER STORING PARAMS
 F469 C328F5    	JMP	PSTOR	;STORE THE VALUES
                ;
                ;    GENERAL ERROR RETURN POINTS FOR STACK CONTROL
                ;
 F46C E1        TERE2:	POP	H
 F46D D1        TERE1:	POP	D
 F46E AF        TERE0:	XRA	A	;CLEAR ALL FLAGS
 F46F 37        	STC		;SET ERROR
 F470 C9        	RET
                ;
                ;
 F471 3D        EOFER:	DCR	A	;SET MINUS FLAGS
 F472 37        	STC		;AND CARRY
 F473 D1        	POP	D	;CLEAR THE STACK
 F474 C9        	RET		;THE FLAGS TELL ALL
                ;
                ;
                ;
                ;
                ;   THIS ROUTINE CLOSES THE FILE BUFFER TO ALLOW ACCESS
                ;   FOR A DIFFERENT CASSETTE OR PROGRAM.  IF THE FILE
                ;   OPERATIONS WERE "WRITE" THEN THE LAST BLOCK IS WRITTED
                ;   OUT AND AN "END OF FILE" WRITTEN TO THE TAPE.  IF
                ;   THE OPERATIONS WERE "READS" THEN THE FILE IS JUST
                ;   MADE READY FOR NEW USE.
                ;
                ;   ON ENTRY:  A - HAS WHICH UNIT (1 OR 2)
                ;
                ;   ERROR RETURNS:  FILE WASN'T OPEN
                ;
                ;
 F475 CDA5F4    PCLOS:	CALL	LFCB	;GET CONTROL BLOCK ADDRESS
 F478 C8        	RZ		;WASN'T OPEN, CARRY IS SET FROM LFCB
 F479 B7        	ORA	A	;CLEAR CARRY
 F47A 3C        	INR	A	;SET CONDITION FLAGS
 F47B 3600      	MVI	M,0	;CLOSE THE CONTROL BYTE
 F47D C8        	RZ		;WE WERE READING...NOTHING MORE TO DO
                ;
                ;    THE FILE OPERATIONS WERE "WRITES"
                ;
                ;  PUT THE CURRENT BLOCK ON THE TAPE
                ;  (EVEN IF ONLY ONE BYTE)
                ;  THEN WRITE AN END OF FILE TO THE TAPE
                ;
                ;
 F47E 23        	INX	H
 F47F 23        	INX	H
 F480 7E        	MOV	A,M	;GET CURSOR POSITION
 F481 7E        	MOV	A,M	;GET CURSOR POSITION
 F482 CD31F5    	CALL	PLOAD	;BC GET HEADER ADDRESS, DE BUFFER ADDRESS
 F485 C5        	PUSH	B	;HEADER TO STACK
 F486 210700    	LXI	H,BLKOF	;OFFSET TO BLOCK SIZE
 F489 09        	DAD	B
 F48A B7        	ORA	A	;TEST COUNT
 F48B CA9DF4    	JZ	EOFW	;NO BYTES...JUST WRITE EOF
                ;
                ;    WRITE LAST BLOCK
                ;
 F48E E5        	PUSH	H	;SAVE BLOCK SIZE POINTER FOR EOF
 F48F 77        	MOV	M,A	;PUT IN COUNT
 F490 23        	INX	H
 F491 3600      	MVI	M,0	;ZERO THE HIGHER BYTE
 F493 23        	INX	H
 F494 73        	MOV	M,E	;BUFFER ADDRESS
 F495 23        	INX	H
 F496 72        	MOV	M,D
 F497 60        	MOV	H,B
 F498 69        	MOV	L,C	;PUT HEADER ADDRESS IN HL
 F499 CDEFF5    	CALL	WFBLK	;GO WRITE IT OUT
 F49C E1        	POP	H	;BLOCK SIZE POINTER
                ;
                ;   NOW WRITE END OF FILE TO CASSETTE
                ;
 F49D AF        EOFW:	XRA	A	;PUT IN ZEROS FOR SIZE:  EOF MARK IS ZERO BYTES!
 F49E 77        	MOV	M,A
 F49F 23        	INX	H
 F4A0 77        	MOV	M,A
 F4A1 E1        	POP	H	;HEADER ADDRESS
 F4A2 C3EFF5    	JMP	WFBLK	;WRITE IT OUT AND RETURN
                ;
                ;
                ;
                ;
                ;   THIS ROUTINE LOCATES THE FILE CONTROL BLOCK POINTED TO
                ;   BY REGISTER "A".  ON RETURN HL POINT TO THE CONTROL BYT
                ;   AND REGISTER "A" HAS THE CONTROL WORD WITH THE FLAGS
                ;   SET FOR IMMEDIATE CONDITION DECISIONS.
                ;
                ;
 F4A5 2150BC    LFCB:	LXI	H,FCBAS	;POINT TO THE BASE OF IT
 F4A8 1F        	RAR		;MOVE THE 1 & 2 TO 0 & 1 LIKE COMPUTERS LIKE
 F4A9 E601      	ANI	1	;SMALL NUMBERS ARE THE RULE
 F4AB 324FBC    	STA	FNUMF	;CURRENT ACCESS FILE NUMBER
 F4AE CAB4F4    	JZ	LFCB1	;UNIT ONE (VALUE OF ZERO)
 F4B1 2157BC    	LXI	H,FCBA2	;UNIT TWO--PT TO ITS FCB
 F4B4 =         LFCB1:	EQU	$	;HL PT TO PROPER FCB
 F4B4 7E        	MOV	A,M	;PICK UP FLAGS FM FCB
 F4B5 B7        	ORA	A	;SET FLAGS BASED ON CONTROL WORD
 F4B6 37        	STC		;SET CARRY IN CASE OF IMMEDIATE ERROR RETURN
 F4B7 C9        	RET
                ;
                ;
                ;
                ;
                ;    READ TAPE BYTE ROUTINE
                ;
                ;    ENTRY:       -  A -  HAS FILE NUMBER
                ;    EXIT: NORMAL -  A -  HAS BYTE
                ;          ERROR
                ;            CARRY SET     - IF FILE NOT OPEN OR
                ;                            PREVIOUS OPERATIONS WERE WRITE
                ;            CARRY & MINUS - END OF FILE ENCOUNTERED
                ;
                ;
                ;
                ;
 F4B8 CDA5F4    RTBYT:	CALL	LFCB	;LOCATE THE FILE CONTROL BLOCK
 F4BB C8        	RZ		;FILE NOT OPEN
 F4BC 3C        	INR	A	;TEST IF FF
 F4BD FA6EF4    	JM	TERE0	;ERROR WAS WRITING
 F4C0 36FF      	MVI	M,(-1) AND 0FFH	;SET IT AS READ  (IN CASE IT WAS JUST OPENED)
 F4C2 23        	INX	H
 F4C3 7E        	MOV	A,M	;GET READ COUNT
 F4C4 E5        	PUSH	H	;SAVE COUNT ADDRESS
 F4C5 23        	INX	H
 F4C6 CD31F5    	CALL	PLOAD	;GET THE OTHER PARAMETERS
 F4C9 E1        	POP	H
 F4CA B7        	ORA	A
 F4CB C2E7F4    	JNZ	GTBYT	;IF NOT EMPTY GO GET BYTE
                ;
                ;  CURSOR POSITION WAS ZERO...READ A NEW BLOCK INTO
                ;  THE BUFFER.
                ;
 F4CE D5        RDNBLK:	PUSH	D	;BUFFER POINTER
 F4CF E5        	PUSH	H	;TABLE ADDRESS
 F4D0 23        	INX	H
 F4D1 CD18F5    	CALL	PHEAD	;PREPARE THE HEADER FOR READ
 F4D4 CD3AF5    	CALL	RFBLK	;READ IN THE BLOCK
 F4D7 DA6CF4    	JC	TERE2	;ERROR POP OFF STACK BEFORE RETURN
 F4DA E1        	POP	H
 F4DB 7B        	MOV	A,E	;LOW BYTE OF COUNT (WILL BE ZERO IF 256)
 F4DC B2        	ORA	D	;SEE IF BOTH ARE ZERO
 F4DD CA71F4    	JZ	EOFER	;BYTE COUNT WAS ZERO....END OF FILE
 F4E0 73        	MOV	M,E	;NEW COUNT ( ZERO IS 256 AT THIS POINT)
 F4E1 23        	INX	H	;BUFFER LOCATION POINTER
 F4E2 3600      	MVI	M,0
 F4E4 2B        	DCX	H
 F4E5 7B        	MOV	A,E	;COUNT TO A
 F4E6 D1        	POP	D	;GET BACK BUFFER ADDRESS
                ;
                ;
                ;
                ;   THIS ROUTINE GETS ONE BYTE FROM THE BUFFER
                ;  AND RETURNS IT IN REGISTER "A".  IF THE END
                ;  OF THE BUFFER IS REACHED IT MOVES THE POINTER
                ;  TO THE BEGINNING OF THE BUFFER FOR THE NEXT
                ;  LOAD.
                ;
 F4E7 3D        GTBYT:	DCR	A	;BUMP THE COUNT
 F4E8 77        	MOV	M,A	;RESTORE IT
 F4E9 23        	INX	H
 F4EA 7E        	MOV	A,M	;GET BUFFER POSITION
 F4EB 34        	INR	M	;BUMP IT
                ;
 F4EC 83        	ADD	E
 F4ED 5F        	MOV	E,A	;DE NOW POINT TO CORRECT BUFFER POSITION
 F4EE D2F2F4    	JNC	RT1
 F4F1 14        	INR	D
 F4F2 1A        RT1:	LDAX	D	;GET CHARACTER FROM BUFFER
 F4F3 B7        	ORA	A	;CLEAR CARRY
 F4F4 C9        	RET		;ALL DONE
                ;
                ;
                ;
                ;
                ;      THIS ROUTINE IS USED TO WRITE A BYTE TO THE FILE
                ;
                ;      ON ENTRY:   A -  HAS FILE NUMBER
                ;                  B -  HAS DATA BYTE
                ;
                ;
 F4F5 CDA5F4    WTBYT:	CALL	LFCB	;GET CONTROL BLOCK
 F4F8 C8        	RZ		;FILE WASN'T OPEN
 F4F9 3C        	INR	A
 F4FA C8        	RZ		;FILE WAS READ
 F4FB 36FE      	MVI	M,0FEH	;SET IT TO WRITE
 F4FD 23        	INX	H
 F4FE 23        	INX	H
 F4FF 78        	MOV	A,B	;GET CHARACTER
 F500 F5        	PUSH	PSW
 F501 E5        	PUSH	H	;SAVE CONTROL ADDRESS+2
                ;
                ;   NOW DO THE WRITE
                ;
 F502 CD31F5    	CALL	PLOAD	;BC GETS HEADER ADDR, DE BUFFER ADDRESS
 F505 E1        	POP	H
 F506 7E        	MOV	A,M	;COUNT BYTE
 F507 83        	ADD	E
 F508 5F        	MOV	E,A
 F509 D20DF5    	JNC	WT1
 F50C 14        	INR	D
 F50D F1        WT1:	POP	PSW	;CHARACTER
 F50E 12        	STAX	D	;PUT CHR IN BUFFER
 F50F B7        	ORA	A	;CLEAR FLAGS
 F510 34        	INR	M	;INCREMENT THE COUNT
 F511 C0        	RNZ		;RETURN IF COUNT DIDN'T ROLL OVER
                ;
                ;   THE BUFFER IS FULL. WRITE IT TO TAPE AND RESET
                ;  CONTROL BLOCK.
                ;
 F512 CD18F5    	CALL	PHEAD	;PREPARE THE HEADER
 F515 C3EFF5    	JMP	WFBLK	;WRITE IT OUT AND RETURN
                ;
                ;
                ;
                ;
                ;  THIS ROUTINE PUTS THE BLOCK SIZE (256) AND BUFFER
                ;  ADDRESS IN THE FILE HEADER.
                ;
 F518 CD31F5    PHEAD:	CALL	PLOAD	;GET HEADER AND BUFFER ADDRESSES
 F51B C5        	PUSH	B	;HEADER ADDRESS
 F51C 210600    	LXI	H,BLKOF-1	;PSTOR DOES AN INCREMENT
 F51F 09        	DAD	B	;HL POINT TO BLOCKSIZE ENTRY
 F520 010001    	LXI	B,256
 F523 CD28F5    	CALL	PSTOR
 F526 E1        	POP	H	;HL RETURN WITH HEADER ADDRESS
 F527 C9        	RET
                ;
                ;
 F528 23        PSTOR:	INX	H
 F529 71        	MOV	M,C
 F52A 23        	INX	H
 F52B 70        	MOV	M,B
 F52C 23        	INX	H
 F52D 73        	MOV	M,E
 F52E 23        	INX	H
 F52F 72        	MOV	M,D
 F530 C9        	RET
                ;
                ;
 F531 23        PLOAD:	INX	H
 F532 4E        	MOV	C,M
 F533 23        	INX	H
 F534 46        	MOV	B,M
 F535 23        	INX	H
 F536 5E        	MOV	E,M
 F537 23        	INX	H
 F538 56        	MOV	D,M
 F539 C9        	RET
                ;
                ;
                ;
                ;
                ;
                ;   THIS ROUTINE SETS THE CORRECT UNIT FOR SYSTEM READS
 F53A CD52F6    RFBLK:	CALL	GTUNT	;SET UP A=UNIT WITH SPEED
                ;
                ;
                ;
                ;
                ;              TAPE READ ROUTINES
                ;
                ;     ON-ENTRY:     A HAS UNIT AND SPEED
                ;                   HL POINT TO HEADER BLOCK
                ;                   DE HAVE OPTIONAL PUT ADDRESS
                ;
                ;     ON EXIT:      CARRY IS SET IF ERROR OCCURED
                ;                   TAPE UNITS ARE OFF
                ;
                ;
 F53D D5        RTAPE:	PUSH	D	;SAVE OPTIONAL ADDRESS
 F53E 0603      	MVI	B,3	;SHORT DELAY
 F540 CD56F6    	CALL	TON
 F543 DB07      	IN	TDATA	;CLEAR THE UART FLAGS
                ;
 F545 E5        PTAP1:	PUSH	H	;HEADER ADDRESS
 F546 CD95F5    	CALL	RHEAD	;GO READ HEADER
 F549 E1        	POP	H
 F54A DA78F5    	JC	TERR	;IF AN ERROR OR ESC WAS RECEIVED
 F54D C245F5    	JNZ	PTAP1	;IF VALID HEADER NOT FOUND
                ;
                ;  FOUND A VALID HEADER NOW DO COMPARE
                ;
 F550 E5        	PUSH	H	;GET BACK AND RESAVE ADDRESS
 F551 1117BC    	LXI	D,THEAD
 F554 CD46F6    	CALL	DHCMP	;COMPARE DE-HL HEADERS
 F557 E1        	POP	H
 F558 C245F5    	JNZ	PTAP1
                ;
                ;
 F55B D1        	POP	D	;OPTIONAL "PUT" ADDRESS
 F55C 7A        	MOV	A,D
 F55D B3        	ORA	E	;SEE IF DE IS ZERO
 F55E 2A1EBC    	LHLD	BLOCK	;GET BLOCK SIZE
 F561 EB        	XCHG		;...TO DE
                ;  DE HAS HBLOCK....HL HAS USER OPTION
 F562 C268F5    	JNZ	RTAP	;IF DE WAS ZERO GET TAPE LOAD ADDRESS
 F565 2A20BC    	LHLD	LOADR	;GET TAPE LOAD ADDRESS
                ;
                ;
                ;     THIS ROUTINE READS "DE" BYTES FROM THE TAPE
                ;     TO ADDRESS HL.  THE BYTES MUST BE FROM ONE
                ;     CONTIGUOUS PHYSICAL BLOCK ON THE TAPE.
                ;
                ;          HL HAS "PUT" ADDRESS
                ;          DE HAS SIZE OF TAPE BLOCK
                ;
 F568 D5        RTAP:	PUSH	D	;SAVE SIZE FOR RETURN TO CALLING PROGRAM
                ;
 F569 =         RTAP2:	EQU	$	;HERE TO LOOP RDING BLKS
 F569 CD87F5    	CALL	DCRCT	;DROP COUNT, B=LEN THIS BLK
 F56C CA82F5    	JZ	RTOFF	;ZERO=ALL DONE
                ;
 F56F CDB6F5    	CALL	RHED1	;READ THAT MANY BYTES
 F572 DA78F5    	JC	TERR	;IF ERROR OR ESC
 F575 CA69F5    	JZ	RTAP2	;RD OK--READ SOME MORE
                ;
                ;  ERROR RETURN
                ;
 F578 AF        TERR:	XRA	A
 F579 37        	STC		;SET ERROR FLAGS
 F57A C383F5    	JMP	RTOF1
                ;
                ;
 F57D 0601      TOFF:	MVI	B,1
 F57F CD56F6    	CALL	DELAY
 F582 AF        RTOFF:	XRA	A
 F583 D306      RTOF1:	OUT	TAPPT	;ZERO TO ACR REGISTER IS OK
 F585 D1        	POP	D	;RETURN BYTE COUNT
 F586 C9        	RET
                ;
                ;
 F587 =         DCRCT:	EQU	$	;COMMON RTN TO COUNT DOWN BLK LENGTHS
 F587 AF        	XRA	A	;CLR FOR LATER TESTS
 F588 47        	MOV	B,A	;SET THIS BLK LEN=256
 F589 B2        	ORA	D	;IS AMNT LEFT < 256
 F58A C292F5    	JNZ	DCRC2	;NO--REDUCE AMNT BY 256
 F58D B3        	ORA	E	;IS ENTIRE COUNT ZERO
 F58E C8        	RZ		;ALL DONE--ZERO=THIS CONDITION
 F58F 43        	MOV	B,E	;SET THIS BLK LEN TO AMNT REMAINING
 F590 5A        	MOV	E,D	;MAKE ENTIRE COUNT ZERO NOW
 F591 C9        	RET		;ALL DONE (NON-ZERO FLAG)
 F592 =         DCRC2:	EQU	$	;REDUCE COUNT BY 256
 F592 15        	DCR	D	;DROP BY 256
 F593 B7        	ORA	A	;FORCE NON-ZERO FLAG
 F594 C9        	RET		;NON-ZERO=NOT DONE YET (BLK LEN=256)
                ;
                ;
                ;   READ THE HEADER
                ;
 F595 060A      RHEAD:	MVI	B,10	;FIND 10 NULLS
 F597 CDCFF5    RHEA1:	CALL	STAT
 F59A D8        	RC		;IF ESCAPE
 F59B DB07      	IN	TDATA	;IGNORE ERROR CONDITIONS
 F59D B7        	ORA	A	;ZERO?
 F59E C295F5    	JNZ	RHEAD
 F5A1 05        	DCR	B
 F5A2 C297F5    	JNZ	RHEA1	;LOOP UNTIL 10 IN A ROW
                ;
                ;    WAIT FOR THE START CHARACTER
                ;
 F5A5 CDE2F5    SOHL:	CALL	TAPIN
 F5A8 D8        	RC		;ERROR OR ESCAPE
 F5A9 FE01      	CPI	1	;ARE WE AT THE 01 YET (START CHAR)
 F5AB DAA5F5    	JC	SOHL	;NO, BUT STIL ZEROES
 F5AE C295F5    	JNZ	RHEAD	;NO, LOOK FOR ANOTHER 10 NULLS
                ;
                ;    WE HAVE  10 (OR MORE) NULLS FOLLOWED IMMEDIATELY
                ;    BY AN 01.  NOW READ THE HEADER.
                ;
 F5B1 2117BC    	LXI	H,THEAD	;POINT TO BUFFER
 F5B4 0610      	MVI	B,HLEN	;LENGTH TO READ
                ;
 F5B6 =         RHED1:	EQU	$	;RD A BLOCK INTO HL FOR B BYTES
 F5B6 0E00      	MVI	C,0	;INIT THE CRC
 F5B8 =         RHED2:	EQU	$	;LOOP HERE
 F5B8 CDE2F5    	CALL	TAPIN	;GET A BYTE
 F5BB D8        	RC
 F5BC 77        	MOV	M,A	;STORE IT
 F5BD 23        	INX	H	;INCREMENT ADDRESS
 F5BE CD1CF6    	CALL	DOCRC	;GO COMPUTE THE CRC
 F5C1 05        	DCR	B	;WHOLE HEADER YET?
 F5C2 C2B8F5    	JNZ	RHED2	;DO ALL THE BYTES
                ;
                ;   THIS ROUTINE GETS THE NEXT BYTE AND COMPARES IT
                ; TO THE VALUE IN REGISTER C.  THE FLAGS ARE SET ON
                ; RETURN.
                ;
 F5C5 CDE2F5    	CALL	TAPIN	;GET CRC BYTE
 F5C8 A9        	XRA	C	;CLR CARRY AND SET ZERO IF MATCH, ELSE NON-ZERO
 F5C9 C8        	RZ		;CRC IS FINE
 F5CA 3A0BBC    	LDA	IGNCR	;BAD CRC, SHD WE STILL ACCEPT IT
 F5CD 3C        	INR	A	;SEE IF IT WAS FF, IF FF THEN ZERO SAYS IGN ERR
                ;   NOW, CRC ERR DETECTION DEPENDS ON IGNCR.
 F5CE C9        	RET
                ;
                ;    THIS ROUTINE GETS THE NEXT AVAILABLE BYTE FROM THE
                ;  TAPE.  WHILE WAITING FOR THE BYTE THE KEYBOARD IS TESTED
                ;  FOR AN ESC COMMAND.  IF RECEIVED THE TAPE LOAD IS
                ;  TERMINATED AND A RETURN TO THE COMMAND MODE IS MADE.
                ;
 F5CF DB06      STAT:	IN	TAPPT	;TAPE STATUS PORT
 F5D1 2F        	CMA		;ACTIVE LOW STATUS
 F5D2 E601      	ANI	TDR
 F5D4 C0        	RNZ
 F5D5 CD1FF0    	CALL	SINP	;CHECK INPUT
 F5D8 CACFF5    	JZ	STAT	;NOTHING THERE YET
 F5DB E67F      	ANI	7FH	;CLEAR PARITY 1ST
 F5DD C2CFF5    	JNZ	STAT	;EITHER MODE OR CTL-@
 F5E0 37        	STC		;SET ERROR FLAG
 F5E1 C9        	RET		;AND RETURN
                ;
                ;
                ;
 F5E2 CDCFF5    TAPIN:	CALL	STAT	;WAIT UNTIL A CHARACTER IS AVAILABLE
 F5E5 D8        	RC
                ;
 F5E6 DB06      TREDY:	IN	TAPPT	;TAPE STATUS
 F5E8 E618      	ANI	TFE+TOE	;DATA ERROR?
 F5EA DB07      	IN	TDATA	;GET THE DATA
 F5EC C8        	RZ		;IF NO ERRORS
 F5ED 37        	STC		;SET ERROR FLAG
 F5EE C9        	RET
                ;
                ;
                ;  THIS ROUTINE GETS THE CORRECT UNIT FOR SYSTEM WRITES
 F5EF CD52F6    WFBLK:	CALL	GTUNT	;SET UP A WITH UNIT AND SPEED
                ;
                ;
                ;
                ;       WRITE TAPE BLOCK ROUTINE
                ;
                ;   ON ENTRY:   A   HAS UNIT AND SPEED
                ;              HL   HAS POINTER TO HEADER
                ;
                ;
 F5F2 =         WTAPE:	EQU	$	;HERE TO WRITE TAPE
 F5F2 E5        	PUSH	H	;SAVE HEADER ADDRESS
 F5F3 CD23F6    	CALL	WHEAD	;TURN ON, THEN WRITE HDR
 F5F6 E1        	POP	H
 F5F7 110700    	LXI	D,BLKOF	;OFFSET TO BLOCK SIZE IN HEADER
 F5FA 19        	DAD	D	;HL POINT TO BLOCK SIZE
 F5FB 5E        	MOV	E,M
 F5FC 23        	INX	H
 F5FD 56        	MOV	D,M	;DE HAVE SIZE
 F5FE 23        	INX	H
 F5FF 7E        	MOV	A,M
 F600 23        	INX	H
 F601 66        	MOV	H,M
 F602 6F        	MOV	L,A	;HL HAVE STARTING ADDRESS
                ;
                ;    THIS ROUTINE WRITES ONE PHYSICAL BLOCK ON THE
                ;  TAPE "DE" BYTES LONG FROM ADDRESS "HL".
                ;
                ;
 F603 =         WTAP1:	EQU	$	;HERE FOR THE EXTRA PUSH
 F603 E5        	PUSH	H	;A DUMMY PUSH FOR LATER EXIT
 F604 =         WTAP2:	EQU	$	;LOOP HERE UNTIL ENTIRE AMOUNT READ
 F604 CD87F5    	CALL	DCRCT	;DROP COUNT IN DE AND SET UP B W/LEN THIS BLK
 F607 CA7DF5    	JZ	TOFF	;RETURNS ZERO IF ALL DONE
 F60A CD37F6    	CALL	WTBL	;WRITE BLOCK FOR BYTES IN B (256)
 F60D C304F6    	JMP	WTAP2	;LOOP UNTIL ALL DONE
                ;
                ;
 F610 F5        WRTAP:	PUSH	PSW
 F611 DB06      WRWAT:	IN	TAPPT	;TAPE STATUS
 F613 2F        	CMA		;ACTIVE LOW SIGNAL
 F614 E680      	ANI	TTBE	;IS TAPE READY FOR A CHAR YET
 F616 CA11F6    	JZ	WRWAT	;NO--WAIT
 F619 F1        	POP	PSW	;YES--RESTORE CHAR TO OUTPUT
 F61A D307      	OUT	TDATA	;SEND CHAR TO TAPE
                ;
 F61C =         DOCRC:	EQU	$	;A COMMON CRC COMPUTATION ROUTINE
 F61C 91        	SUB	C
 F61D 4F        	MOV	C,A
 F61E A9        	XRA	C
 F61F 2F        	CMA
 F620 91        	SUB	C
 F621 4F        	MOV	C,A
 F622 C9        	RET		;ONE  BYTE NOW WRITTEN
                ;
                ;
                ;   THIS ROUTINE WRITES THE HEADER POINTED TO BY
                ;   HL TO THE TAPE.
                ;
 F623 =         WHEAD:	EQU	$	;HERE TO 1ST TURN ON THE TAPE
 F623 CD54F6    	CALL	WTON	;TURN IT ON, THEN WRITE HEADER
 F626 1632      	MVI	D,50	;WRITE 50 ZEROS
 F628 AF        NULOP:	XRA	A
 F629 CD10F6    	CALL	WRTAP
 F62C 15        	DCR	D
 F62D C228F6    	JNZ	NULOP
                ;
 F630 3E01      	MVI	A,1
 F632 CD10F6    	CALL	WRTAP
 F635 0610      	MVI	B,HLEN	;LENGTH TO WRITE OUT
                ;
 F637 0E00      WTBL:	MVI	C,0	;RESET CRC BYTE
 F639 7E        WLOOP:	MOV	A,M	;GET CHARACTER
 F63A CD10F6    	CALL	WRTAP	;WRITE IT TO THE TAPE
 F63D 05        	DCR	B
 F63E 23        	INX	H
 F63F C239F6    	JNZ	WLOOP
 F642 79        	MOV	A,C	;GET CRC
 F643 C310F6    	JMP	WRTAP	;PUT IT ON THE TAPE AND RETURN
                ;
                ;
                ;   THIS ROUTINE COMPARES THE HEADER IN THEAD TO
                ;   THE USER SUPPLIED HEADER IN ADDRESS HL.
                ;   ON RETURN IF ZERO IS SET THE TWO NAMES COMPARED
                ;
 F646 0605      DHCMP:	MVI	B,5
 F648 1A        DHLOP:	LDAX	D
 F649 BE        	CMP	M
 F64A C0        	RNZ
 F64B 05        	DCR	B
 F64C C8        	RZ		;IF ALL FIVE COMPARED
 F64D 23        	INX	H
 F64E 13        	INX	D
 F64F C348F6    	JMP	DHLOP
                ;
 F652 =         GTUNT:	EQU	$	;SET A=SPEED + UNIT
 F652 AF        	XRA	A	;JUST RETURN ZERO FOR ACR
 F653 C9        	RET
                ;
 F654 0604      WTON:	MVI	B,4	;SET LOOP DELAY  (BIT LONGER ON A WRITE)
 F656 =         TON:	EQU	$	;HERE TO TURN A TAPE ON THEN DELAY
                ;	OUT	TAPPT	;DON'T SEND TAPE ON COMMAND TO ACR
                ;
 F656 110000    DELAY:	LXI	D,0
 F659 1B        DLOP1:	DCX	D
 F65A 7A        	MOV	A,D
 F65B B3        	ORA	E
 F65C C259F6    	JNZ	DLOP1
 F65F 05        	DCR	B
 F660 C256F6    	JNZ	DELAY
 F663 C9        	RET
                
                ;----------------------------------------------------------
                ;  HXGET - LOAD INTEL HEX FILE
                ;     OPTIONAL PARAMETER SPECIFIES PSEUDO PORT TO USE
                ;----------------------------------------------------------
 F664 2106BC    HXGET:	lxi	h,IPORT		;hl->current input port
 F667 CDA5F7    	call	setHxPt		;set port, display xfer prompt
                
                ; Look for new record
                
 F66A CDDBF1    intelCr	call	CRLF
 F66D 0E00      	mvi	c,0		;clear echo character flag
 F66F CDD5F6    intel	call	getChar		;read next character
 F672 D63A      	sui	':'		;record marker?
 F674 C26FF6    	jnz	intel		;no, keep looking
                
                ; Have start of new record. Save the byte count and load address.
                ;   The load address is echoed to the screen so the user can
                ;   see the file load progress.
                
 F677 57        	mov	d,a		;init checksum in D to zero
 F678 CDB9F6    	call	iByte		;input two hex digits (byte count)
 F67B 7B        	mov	a,e		;test for zero byte count
 F67C B7        	ora	a
 F67D CAA4F6    	jz	flush		;count of 0 means end
                
 F680 43        	mov	b,e		;B = byte count on line
 F681 0C        	inr	c		;set echo flag for address bytes
 F682 CDB9F6    	call	iByte		;get MSB of address
 F685 63        	mov	h,e		;H = address MSB
 F686 CDB9F6    	call	iByte		;get LSB of address
 F689 6B        	mov	l,e		;L = address LSB
 F68A 0E00      	mvi	c,0		;clear echo flags
 F68C CDB9F6    	call	iByte		;ignore record type
                
                ; Receive the data bytes of the record and move to memory
                
 F68F CDB9F6    data	call	iByte		;read a data byte (2 hex digits)
 F692 73        	mov	m,e		;store in memory
 F693 23        	inx	h
 F694 05        	dcr	b
 F695 C28FF6    	jnz	data
                
                ; Validate checksum
                
 F698 CDB9F6    	call	iByte		;read and add checksum
 F69B CA6AF6    	jz	intelCr		;checksum good
 F69E 21F1F7    error	lxi	h,mError	;display error message
 F6A1 CDBCF7    	call	dispMsg
                				;fall through to flush
                
                ; flush - flush rest of file as it comes in until no characters
                ;    received for about 1/4 second. The AINP call takes about
                ;    136 cycles.
                
 F6A4 11B80B    flush	lxi	d,3000		;.25s timeout for 160 cycle loop
 F6A7 3A0CBC    flshLp	lda	HPORT		;a=pseudo port to flush
 F6AA CD22F0    	call	AINP
 F6AD C2A4F6    	jnz	flush		;character received, restart
 F6B0 1B        	dcx	d		;(5) otherwise, decrement timeout
 F6B1 7A        	mov	a,d		;(5)
 F6B2 B3        	ora	e		;(4)
 F6B3 C2A7F6    	jnz	flshLp		;(10) loop until zero
 F6B6 C3C3F0    	jmp	COMND		;back to CUTER command loop
                
                ;-----------------------------------------------------------
                ; iByte	- read two ascii hex bytes and return binary
                ;    value in e. If a conversion error occurs, exit
                ;    directly to error label above.
                ;-----------------------------------------------------------
 F6B9 CDD5F6    iByte	call	getChar		;get a character
 F6BC CD34F2    	call	HCOV1		;ascii hex digit to binary
 F6BF D29EF6    	jnc	error
 F6C2 87        	add	a		;put in msn, zero lsn
 F6C3 87        	add	a
 F6C4 87        	add	a
 F6C5 87        	add	a
 F6C6 5F        	mov	e,a		;save byte with MSN in E
                
                ; 2nd byte (LSN)
                
 F6C7 CDD5F6    	call	getChar		;get a character
 F6CA CD34F2    	call	HCOV1		;ascii hex digit to binary
 F6CD D29EF6    	jnc	error
 F6D0 83        	add	e		;combine msn and lsn
 F6D1 5F        	mov	e,a		;save in E
 F6D2 82        	add	d		;add character to checksum
 F6D3 57        	mov	d,a
 F6D4 C9        	ret		
                
                ;-------------------------------------------------------------
                ; getChar - read a character from pseudo port specified in
                ;    HPORT. The character is also echoed to the console port
                ;    if the echo flag (c) is set (non-zero)
                ;-------------------------------------------------------------
 F6D5 C5        getChar	push	b		;save b,c
 F6D6 3A0CBC    wtChar	lda	HPORT		;a=pseudo port to use
 F6D9 CD22F0    	call	AINP
 F6DC CAD6F6    	jz	wtChar		;wait for byte
 F6DF FE00      	cpi	MODE		;MODE button (ctrl@)?
 F6E1 CAC3F0    	jz	COMND		;yes, exit completely
 F6E4 47        	mov	b,a		;save character in b
 F6E5 79        	mov	a,c		;echo flag (c) set?
 F6E6 B7        	ora	a
 F6E7 CAEFF6    	jz	noEcho		;no echo
 F6EA CD19F0    	call	SOUT		;echo character in b
 F6ED C1        	pop	b		;restore b,c
 F6EE C9        	ret			;byte is in a
                
 F6EF 78        noEcho	mov	a,b		;a=byte read
 F6F0 C1        	pop	b		;restore b,c
 F6F1 C9        	ret
                
                ;----------------------------------------------------------
                ;  HXSAVE - SAVE MEMORY RANGE AS INTEL HEX FILE
                ;     PARAMETER 1 - STARTING ADDRESS
                ;     PARAMETER 2 - ENDING ADDRESS
                ;     PARAMETER 3 (OPTIONAL) PSEUDO PORT TO USE
                ;----------------------------------------------------------
 F6F2 CD11F2    HXSAVE:	call	SCONV		;get start address in HL
 F6F5 E5        	push	h		;save start
 F6F6 CD11F2    	call	SCONV		;get end address in HL
 F6F9 E5        	push	h		;save end address
 F6FA 2107BC    	lxi	h,OPORT		;hl->current output port
 F6FD CDA5F7    	call	setHxPt		;set port, display xfer prompt
 F700 21DBF7    	lxi	h,mReady	;return when ready prompt
 F703 CDBCF7    	call	dispMsg
 F706 CD1FF0    wtReady	call	SINP		;wait for any character
 F709 CA06F7    	jz	wtReady
 F70C FE00      	cpi	MODE		;MODE button (ctrl@)?
 F70E CAC3F0    	jz	COMND		;yes, exit completely
                
                ; Get dump address in HL and length in DE
                
 F711 D1        	pop	d		;de=end address
 F712 E1        	pop	h		;hl=start address
 F713 7B        	mov	a,e		;compute de=de-hl + 1
 F714 95        	sub	l
 F715 5F        	mov	e,a
 F716 7A        	mov	a,d
 F717 9C        	sbb	h
 F718 57        	mov	d,a
 F719 13        	inx	d		
                
                ; sndLine - send a line of hex data
                
 F71A 063A      sndLine	mvi	b,':'		;transmit leading ":"
 F71C CD95F7    	call	sndChar
 F71F 0600      	mvi	b,0		;init checksum in b
 F721 CD65F7    	call	sndLen		;transmit length (returned in c)
 F724 7C        	mov	a,h		;send high byte of address
 F725 CD76F7    	call	sndByte
 F728 7D        	mov	a,l		;send low byte of address
 F729 CD76F7    	call	sndByte
 F72C AF        	xra	a		;send record type (00)
 F72D CD76F7    	call	sndByte
                
                ; sndLoop - send data bytes of the line
                
 F730 7E        sndLoop	mov	a,m		;send next data byte
 F731 CD76F7    	call	sndByte
 F734 23        	inx	h		;point to next byte
 F735 0D        	dcr	c		;bytes per line counter
 F736 C230F7    	jnz	sndLoop
                
                ; send checksum and CR/LF
                
 F739 78        	mov	a,b		;a=checksum before 2's compliment
 F73A 2F        	cma			;compute 2's compliment
 F73B 3C        	inr	a		;a=2's compliment checksum
 F73C CD76F7    	call	sndByte
 F73F CD9BF7    	call	sndCrLf		;send CR/LF through HPORT
                
                ; if de <= zero, we're done, otherwise repeat at sndLine
                
 F742 7A        	mov	a,d		;msb of count < 0?
 F743 B7        	ora	a
 F744 FA4FF7    	jm	sndDone		;yes, we're done
 F747 C21AF7    	jnz	sndLine		;not zero, do another line
 F74A 7B        	mov	a,e		;d is zero, is e zero too?
 F74B B7        	ora	a
 F74C C21AF7    	jnz	sndLine		;no, do another line
                
                ; sndDone - all bytes sent, send EOF record
                
 F74F 063A      sndDone	mvi	b,':'		;send leading ":"
 F751 CD95F7    	call	sndChar
 F754 0E0A      	mvi	c,10		;send 10 ascii zeros
 F756 0630      eofLoop	mvi	b,'0'
 F758 CD95F7    	call	sndChar	
 F75B 0D        	dcr	c
 F75C C256F7    	jnz	eofLoop
 F75F CD9BF7    	call	sndCrLf		;trailing CR/LF
 F762 C3C3F0    	jmp	COMND		;back to command processor
                
                ;----------------------------------------------------------
                ; sndLen - compute how many bytes will be sent in this
                ;    line (typically 16) and transmit the count as two
                ;    hex digits. The length is returned in c
                ;----------------------------------------------------------
 F765 0E10      sndLen	mvi	c,16		;assume 16 byte length
 F767 7B        	mov	a,e		;compute de=de-16
 F768 91        	sub	c
 F769 5F        	mov	e,a
 F76A 7A        	mov	a,d
 F76B DE00      	sbi	0
 F76D 57        	mov	d,a
 F76E D275F7    	jnc	haveLen
                
                ; length went below zero, compute number of bytes to send
                
 F771 7B        	mov	a,e		;a=lsb of de < 0
 F772 C610      	adi	16		;a=bytes left
 F774 4F        	mov	c,a		;c=bytes to send
                
                ; haveLen - have length to send in c, transmit the length
                
 F775 79        haveLen	mov	a,c		;a=bytes in line
                				;fall through to sndByte
                
                ;----------------------------------------------------------
                ; sndByte - send the byte in A as two ascii hex digits.
                ;     checksum is accumulated in b.
                ;----------------------------------------------------------
 F776 F5        sndByte	push	a		;save passed character
 F777 80        	add	b		;update checksum
 F778 47        	mov	b,a		;save in b
 F779 F1        	pop	a		;a=passed character
 F77A C5        	push	b		;save b,c
 F77B 4F        	mov	c,a		;c=passed character
 F77C 0F        	rrc			;put in lsn
 F77D 0F        	rrc
 F77E 0F        	rrc
 F77F 0F        	rrc
 F780 CD89F7    	call	sndNib		;send the MSN
 F783 79        	mov	a,c		;a=original character
 F784 CD89F7    	call	sndNib		;send the LSN
 F787 C1        	pop	b		;restore b,c
 F788 C9        	ret
                
                ; sndNib - convert nibble in a to ascii hex and transmit
                
 F789 E60F      sndNib	ani	0fh		;get lower nibble alone
 F78B C630      	adi	30h		;convert to ASCII
 F78D FE3A      	cpi	3ah		;digit 0-9
 F78F DA94F7    	jc	xmtNib		;yes, send it	
 F792 C607      	adi	7		;convert to "A-F"
 F794 47        xmtNib	mov	b,a		;b=character to send
                
                ; sndChar - send character in b through port in HPORT
                
 F795 3A0CBC    sndChar	lda	HPORT
 F798 C31CF0    	jmp	AOUT
                
                ; sndCrLf - send CR/LF through port in HPORT
                
 F79B 060D      sndCrLf	mvi	b,CR
 F79D CD95F7    	call	sndChar
 F7A0 060A      	mvi	b,LF
 F7A2 C395F7    	jmp	sndChar
                
                ;----------------------------------------------------------
                ; setHxPt - Set hex transfer psedueo port.
                ;     Enter with HL->default port number, this function
                ;     gets the optional port number from the command line
                ;     if present. The default or specified port number is
                ;     then stored in HPORT and a file transfer prompt with
                ;     the port number is displayed. 
                ;----------------------------------------------------------
 F7A5 6E        setHxPt	mov	l,m		;l=current input or output port
 F7A6 CD3EF2    	call	PSCAN		;get optional port parameter
 F7A9 7D        	mov	a,l		;a=specified port
 F7AA E603      	ani	3		;limit to 0-3
 F7AC 320CBC    	sta	HPORT		;port HPORT for hex transfer
                
                ; Display message to send the file, then loop receiving 
                ;    and storing the hex file.
                
 F7AF C630      	adi	'0'		;get ASCII for port number
 F7B1 4F        	mov	c,a		;save in c
 F7B2 21C7F7    	lxi	h,mXfer		;hl->file transfer message
 F7B5 CDBCF7    	call	dispMsg		;display message
 F7B8 41        	mov	b,c		;b=port number in ASCII
 F7B9 C319F0    	jmp	SOUT		;display port and return
                
                ;------------------------------------------------------------
                ; dispMsg - display the null-terminated message passed in hl
                ;    on the default pseudo port.
                ;------------------------------------------------------------
 F7BC 7E        dispMsg	mov	a,m		;get the next message byte
 F7BD B7        	ora	a		;null terminates
 F7BE C8        	rz
 F7BF 47        	mov	b,a		;display it
 F7C0 CD19F0    	call	SOUT
 F7C3 23        	inx	h		;move to next byte
 F7C4 C3BCF7    	jmp	dispMsg
                
                ;------------------------------------------------------------
                ;  Messages
                ;-----------------------------------------------------------
 F7C7 0D0A53656EmXfer	db	cr,lf,'Send/Rcv on port ',0
 F7DB 2C20524554mReady	db	', RETURN when ready',cr,lf,0
 F7F1 0D0A0A4865mError	db	cr,lf,lf,'Hex error',cr,lf,0
                
 F800 =         nxtAddr	equ	$
                
                ;
                ;
                ;**** -- END OF PROGRAM--
                ;
                ;
                ;
                ;
                ;    S Y S T E M    E Q U A T E S
                ;
                ;
                ;            KEYBOARD SPECIAL KEY ASSIGNMENTS
                ;
                ;  THESE DEFINITIONS ARE DESIGNED TO ALLOW
                ;  COMPATABILITY WITH SOLOS(TM). THESE ARE THE
                ;  SAME KEYS WITH BIT 7 (X'80') STRIPPED OFF.
                ;
 0000 =         MODE:	EQU	00H	;CTL-@
 000A =         LF:	EQU	10
 000D =         CR:	EQU	13
 0008 =         BS:	EQU	08	;ASCII BACKSPACE
                ;
                ;          PORT ASSIGNMENTS
                ;
 0010 =         SIO1CSR	EQU	10H	;2SIO PORT 1 CONTROL/STATUS REGISTER
 0011 =         SIO1DR	EQU	11H	;2SIO PORT 1 DATA REGISTER
 0012 =         SIO2CSR	EQU	12H	;2SIO PORT 2 CONTROL/STATUS REGISTER
 0013 =         SIO2DR	EQU	13H	;2SIO PORT 2 DATA REGISTER
                ;
 0004 =         PIOCSR	EQU	04H	;PIO CONTROL/STATUS REGISTER
 0005 =         PIODR	EQU	05H	;PIO DATA REGISTER
                ;
 0006 =         TAPPT:	EQU	06H	;TAPE STATUS PORT (ACR)
 0007 =         TDATA:	EQU	07H	;TAPE DATA PORT (ACR)
 00FF =         SENSE:	EQU	0FFH	;SENSE SWITCHES
                ;
                ;
                ;
                ;          BIT ASSIGNMENT MASKS
                ;
 0001 =         SIORDRF	EQU	01H	;BIT MASK FOR 2SIO RECEIVE DATA AVAILABLE
 0002 =         SIOTDRE	EQU	02H	;BIT MASK FOR 2SIO TRANSMIT READY
                ;
 0002 =         PIORDRF	EQU	02H	;BIT MASK FOR PIO RECEIVE DATA AVAILABLE
 0001 =         PIOTDRE	EQU	01H	;BIT MASK FOR PIO TRANSMIT READY
                ;
 0010 =         TFE:	EQU	10H	;TAPE FRAMING ERROR
 0008 =         TOE:	EQU	08H	;TAPE OVERFLOW ERROR
 0001 =         TDR:	EQU	01H	;TAPE DATA READY
 0080 =         TTBE:	EQU	80H	;TAPE TRANSMITTER BUFFER EMPTY
                ;
                ;
                ;
                ;
                ;       S Y S T E M   G L O B A L    A R E A
                ;
 BC00           	ORG	RAMADDR	
                ;
 BC00 =         SYSRAM:	EQU	$	;START OF SYSTEM RAM
 BFFF =         SYSTP:	EQU	SYSRAM+3FFH	;STACK WORKS FM TOP DOWN
                ;
                ;
                ;   PARAMETERS STORED IN RAM
                ;
 BC00           UIPRT:	DS	2	;USER DEFINED INPUT RTN IF NON ZERO
 BC02           UOPRT:	DS	2	;USER DEFINED OUTPUT RTN IF NON ZERO
 BC04           DFLTS:	DS	2	;DEFAULT PSUEDO I/O PORTS
 BC06           IPORT:	DS	1	;CRNT INPUT PSUEDO PORT
 BC07           OPORT:	DS	1	;CRNT OUTPUT PSUEDO PORT
 BC08           INPTR:	DS	2	;PTR TO NEXT CHAR POSITION IN INLIN
 BC0A           NUCNT:	DS	1	;NUMBER OF NULLS AFTER CRLF
 BC0B           IGNCR:	DS	1	;IGN CRC ERR FLAG, FF=IGN CRC ERRS, ELSE=NORMAL
 BC0C           HPORT	DS	1	;PORT USED FOR HEX LOAD/SAVE
                ;
 BC0D           	DS	10	;ROOM FOR FUTURE EXPANSION
                ;
                ; * * * * * * * * * * * * * * * * * * * * * * * * * * * * *
                ;    T H I S   I S   T H E   H E A D E R   L A Y O U T    *
                ; * * * * * * * * * * * * * * * * * * * * * * * * * * * * *
                ;
 BC17           THEAD:	DS	5	;NAME
 BC1C           	DS	1	;THIS BYTE MUST BE ZERO
 BC1D           HTYPE:	DS	1	;TYPE
 BC1E           BLOCK:	DS	2	;BLOCK SIZE
 BC20           LOADR:	DS	2	;LOAD ADDRESS
 BC22           XEQAD:	DS	2	;AUTO EXECUTE ADDRESS
 BC24           HSPR:	DS	3	;SPARES
                ;
 0010 =         HLEN:	EQU	$-THEAD	;LENGTH OF HEADER
 0007 =         BLKOF:	EQU	BLOCK-THEAD	;OFFSET TO BLOCK SIZE
 BC27           DHEAD:	DS	HLEN	;A DUMMY HDR FOR COMPARES WHILE RD'ING
                ;
                ;
 BC37           CUTAB:	DS	6*4	;ROOM FOR UP TO 6 CUSTOM USER COMMANDS
                ;
                ;
 BC4F           FNUMF:	DS	1	;FOR CURRENT FILE OPERATIONS
 BC50           FCBAS:	DS	7	;1ST FILE CONTROL BLOCK
 BC57           FCBA2:	DS	7	;2ND FILE CONTROL BLOCK
 BC5E           FBUF1:	DS	2*256	;SYSTEM FILE BUFFER BASE
 BE5E           	DS	1	;"BELL" (X'07') FLAGS START OF INPUT BFR
 BE5F           INLIN:	DS	80	;ROOM FOR THE INPUT LINE
 BEAF =         USARE:	EQU	$	;START OF USER AREA
                ;
                ;   REMEMBER THAT THE STACK WORKS ITS WAY DOWN-FROM
                ;   THE END OF THIS 1K RAM AREA.
                ;
                ; -*-
