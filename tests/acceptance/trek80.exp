#!/usr/bin/expect -f
#
# THE SHIPPED SOL-20 EXAMPLE MUST LOAD ITS GAME OFF THE CASSETTE.
#
# examples/sol is product, not a fixture: trek80.toml, a tape, and a README that tells the
# reader to type two words. This runs those two words. It proves the whole path end to end --
# SOLOS's own tape reader, the `sol` board's motor and 0FBh data register, the CUTS modem when
# the media is a .WAV, the VDM-1 screen the game paints on -- against a 1977 artifact.
#
# AND IT PROVES THE TAPE ITSELF, which is the part that could not be proven any other way.
# TRK80.TAP is DERIVED (examples/sol/make-trek80-tape.sh writes it by getting SOLOS to SAVE
# the archived .ENT image). A SOLOS tape carries a header checksum and a checksum after every
# 256-byte block, and a tape whose checksums are wrong is INVISIBLE -- `CA` lists nothing, `GE`
# reports nothing, and there is no error anywhere to tell you why. So the only honest test of
# the derivation is to make SOLOS read it back.
#
# WHY THE VERDICT IS A MEMORY DUMP AND NOT THE TERMINAL. The Sol-20's screen is the VDM-1's
# RAM at 0CC00H. TREK80 writes there; nothing it prints ever reaches stdout. So the machine is
# stopped with ATTN and the screen is READ -- which is also the only way this test could run
# headless in CI, with no window and no SDL.
#
# usage: expect -f trek80.exp <altairsim> <example-dir> <tap|wav>
#
set timeout 120
log_user 0

set exe  [lindex $argv 0]
set dir  [lindex $argv 1]
set kind [lindex $argv 2]

if {$kind eq "wav"} {
    set media "TRK80.WAV"
} else {
    set media "TRK80.TAP"
}

cd $dir

# FLAT OUT, ON PURPOSE, AND IT IS AN OVERRIDE OF THE EXAMPLE. trek80.toml sets the Sol-20's
# real 2.045 MHz because that is the speed the game was played at, and at that speed the
# cassette takes the minute a cassette took. A test does not want the minute; it wants the
# bytes. `clock_hz=0` buys back the wall clock and changes nothing the guest can observe.
#
# `idle=false` IS INSURANCE, and it is honest to say it changes nothing measurable here (the
# test runs in the same 7 seconds either way). The reason to set it anyway: reading a cassette
# IS a poll loop -- SOLOS sits on the tape status register -- and the idle policy decides
# "waiting for a person" from CONSOLE traffic, which a byte arriving on the TAPE is not. On a
# slower box, or with this test's own stop-and-look restarting the warmup, a machine that is
# working could be taken for one at a prompt. Nothing here needs the nap.
#
# `-i` KEEPS THE MONITOR ALIVE after the -x commands. Without it altairsim runs them and
# EXITS, and every expect below fails with a broken pipe rather than a verdict.
spawn $exe trek80.toml -i \
      -x "MOUNT sol0:tape1 \"$media\"" \
      -x "SET cpu0 clock_hz=0" \
      -x "SET cpu0 idle=false" \
      -x "RUN 0C000"

expect {
    -ex "console -- " {}
    eof     { puts "FAIL: the machine did not start -- see the error above"; exit 1 }
    timeout { puts "FAIL: never reached the guest console"; exit 1 }
}

# SOLOS has to be at its prompt before it will look at the keyboard. It clears the screen and
# signs on first, and a byte sent before that is a byte thrown away.
sleep 2
send "XE TRK80\r"

# NOW POLL, rather than guess a sleep. ATTN stops the machine without disturbing it (it is
# not RESET), so the screen can be read and the machine sent on its way as many times as we
# like. A fixed sleep long enough for the .WAV would be dead time on the .TAP, and a fixed
# sleep long enough for a loaded CI box is a fixed sleep nobody notices has become the whole
# test.
#
# DO NOT MATCH THE PROMPT TO DECIDE "NOT YET", which is the trap this walked into once. The
# monitor ECHOES what we type and redraws its prompt on every keystroke, so the reply to
# `DUMP ...` opens with two dozen copies of "altairsim> " before a single byte of the dump
# arrives. An expect alternation of {copyright | prompt} therefore always takes the prompt
# branch, the loop concludes "not loaded" forever, and the test fails on a machine that is
# working perfectly.
#
# So: wait for the DUMP's OWN first token -- "CD00  ", two spaces, which the echoed command
# (`DUMP CD00-CD3F`) cannot forge -- and only then look at the row that follows.
set found 0
for {set try 0} {$try < 20 && !$found} {incr try} {
    sleep 5
    send "\005"
    expect {
        -ex "altairsim> " {}
        eof     { puts "FAIL: the machine died while loading the tape"; exit 1 }
        timeout { puts "FAIL: ATTN did not return to the monitor"; exit 1 }
    }

    # The line TREK80 paints first, read as one 64-byte row because the VDM's screen is 64
    # columns and a row is contiguous. DUMP prints the ASCII alongside the hex.
    send "DUMP CD00-CD3F WIDTH=64\r"
    expect {
        -ex "CD00  " {}
        eof     { puts "FAIL: the machine died at the monitor prompt"; exit 1 }
        timeout { puts "FAIL: DUMP did not answer -- the monitor is wedged"; exit 1 }
    }
    expect {
        -ex "COPYRIGHT (C) 1977  PROCESSOR TECHNOLOGY CORP." { set found 1 }
        -ex "altairsim> " {}
        timeout { puts "FAIL: DUMP printed a row and then stopped"; exit 1 }
    }

    if {!$found} {
        send "RUN\r"
        expect {
            -ex "console -- " {}
            eof     { puts "FAIL: the machine would not resume"; exit 1 }
            timeout { puts "FAIL: RUN did not resume the machine"; exit 1 }
        }
    }
}

if {!$found} {
    puts "FAIL: `XE TRK80` never reached the game off $media.\
          The Sol-20 sat at SOLOS's prompt, or the tape's checksums do not read back --\
          a bad SOLOS tape is SILENT, so this is what that failure looks like."
    exit 1
}

# THE COPYRIGHT LINE ALONE IS NOT ENOUGH. It is the first thing TREK80 paints, and a partly
# loaded image can reach it. The speed-factor prompt is the program RUNNING: it is written
# after the load finished, from code near the end of the image, and it is where TREK80 stops
# to ask the operator a question.
send "DUMP CFC0-CFFF WIDTH=64\r"
expect {
    -ex "CFC0  " {}
    timeout { puts "FAIL: DUMP did not answer"; exit 1 }
}
expect {
    -ex "ENTER SPEED FACTOR (9(SLOW)-0(FAST))" {}
    timeout { puts "FAIL: the copyright is on the screen but the game never asked for a\
                    speed factor -- the image loaded short, or it is not running."; exit 1 }
}

send "QUIT\r"
expect eof

puts "OK: XE TRK80 off $media reached the game -- the copyright line and the speed-factor\
      prompt are both on the VDM-1's screen."
exit 0
