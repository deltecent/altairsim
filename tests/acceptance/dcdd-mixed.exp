#!/usr/bin/expect -f
#
# TWO DISK GEOMETRIES, ONE CONTROLLER, AT THE SAME TIME.
#
# An 8 MB image (2048 tracks) in drive 0 and an ordinary 8" floppy image (77 tracks) in
# drive 2, both in the same 88-DCDD, both live. This is not a stunt -- it is what the FDC+
# manual tells you to do (3.7.4, quoted in disks/mits-88dcdd/cpm22/8mb/README.md):
#
#     "CP/M for these drives expects an 8Mb drive image to be mounted on drives A and B
#      (0 and 1) and normal 77 track Altair images on drives C and D (2 and 3)."
#
# ...and it is the only way to move files between an 8 MB system and a floppy, since the
# 8 MB BIOS has no other door.
#
# IT WORKS BECAUSE THE FORMAT AND THE SPINDLE ARE PER DRIVE, NOT PER CARD. The controller
# steps a head and shifts bytes; nothing in it asks how big the disk is meant to be. A
# 2048-track disk and a 77-track one turn the same 32 sectors past the head. If anything in
# the card ever gets promoted from the drive to the card -- a track count, a sector map, a
# format -- this test is what notices, and it notices as CORRUPTION, not as an error.
#
# WHICH IS WHY THE ASSERTION IS BYTES AND NOT A DIRECTORY LISTING. Skew, DPB and track
# arithmetic all have failure modes where the file is THERE and the CONTENTS ARE WRONG. So
# both directions are checked byte-for-byte, against files that are in git:
#
#     read   C: -> host    W C:R.COM  ...  = cpm/hostbridge/R.COM
#     write  A: -> C:      PIP, then W it back out  = cpm/hostbridge/HDIR.COM
#
# AND IT DOUBLES AS THE REGRESSION TEST FOR THE 24K IMAGE (bug #7). Reading R.COM off C:
# only works because R/W/HDIR are on that image -- which this test puts there itself, on a
# scratch copy, below. See disks/mits-88dcdd/cpm22/buffered/README.md.
#
# THE REPOSITORY'S IMAGES ARE NEVER TOUCHED. Both are copied into the build tree first, and
# the write half of this test would otherwise land in one of them.
#
# usage: expect -f dcdd-mixed.exp <altairsim> <srcdir> <workdir>
#
set timeout 90
log_user 0

set sim  [lindex $argv 0]
set src  [lindex $argv 1]
set work [lindex $argv 2]

file delete -force $work
file mkdir $work/host

file copy "$src/disks/mits-88dcdd/cpm22/8mb/CPM22-8MB-56K.DSK"          "$work/8mb.dsk"
file copy "$src/disks/mits-88dcdd/cpm22/buffered/cpm22b23-24k.dsk"      "$work/8in.dsk"

# R/W/HDIR GO ONTO THE COPIES, HERE, AND NOT INTO THE IMAGES ON DISK. They are ours, so a
# disk fetched from deramp.com does not have them and this test cannot run without them --
# but installing them where the images LIVE would mean tools/fetch-disk-images.sh had to
# write to what it just downloaded, and then the pinned checksum could never match again.
# Fetch keeps the original pristine and verifiable; the test prepares its own scratch copy.
# It is two boots per image and it is what makes the fetch a pure download.
set env(ALTAIRSIM) $sim
if {[catch {exec sh "$src/tools/install-hostbridge-utils.sh" "$work/8mb.dsk" "$work/8in.dsk"} why]} {
    puts "FAIL: could not install the host-bridge utilities onto the scratch images:\n$why"
    exit 1
}

set cmd [open "$work/boot.cmd" w]
puts $cmd "SET CONSOLE UPPER=OFF"
puts $cmd "SET hb0 HOSTDIR=$work/host"
puts $cmd "MOUNT dsk0:drive0 \"$work/8mb.dsk\""
puts $cmd "MOUNT dsk0:drive2 \"$work/8in.dsk\""
puts $cmd "RUN FF00"
close $cmd

# NO `media` ON EITHER MOUNT, AND THAT IS HALF THE POINT: the card probes each image on its
# own and reaches two different answers -- fdc8mb for one, 8in for the other -- on one card.
proc bad {why} { puts "FAIL: $why"; exit 1 }

spawn $sim -s $work/boot.cmd

expect {
    -ex "For Altair 8Mb Virtual Drive" {}
    eof     { bad "the 8 MB system did not boot" }
    timeout { bad "the 8 MB system did not boot" }
}
expect {
    -ex "A0>" {}
    timeout   { bad "no CP/M prompt" }
}

# TWO GEOMETRIES, AND CP/M CAN SEE BOTH OF THEM. An 8 MB disk has megabytes free and a
# floppy has kilobytes; if the card had forced one format on the whole controller, one of
# these two numbers would be absurd -- or the drive would not answer at all.
proc freespace {drive} {
    send "STAT $drive:\r"
    expect {
        -re "Bytes Remaining On $drive: *(\[0-9\]+)k" { return $expect_out(1,string) }
        timeout { bad "STAT $drive: never answered -- the drive did not respond" }
    }
}
set afree [freespace A]
set cfree [freespace C]
expect -ex "A0>"

if {$afree < 1000} { bad "A: is the 8 MB disk but STAT says ${afree}k free -- it is not being read as 2048 tracks" }
if {$cfree > 1000} { bad "C: is a 77-track floppy but STAT says ${cfree}k free -- the 8 MB geometry has leaked onto it" }

# READ: a file off the 77-track disk, out through the bridge, byte for byte. R.COM is on C:
# because bug #7 put it there, and this is the check that it stays there.
#
# THE PROMPT IS ONE OF THE FAILURE BRANCHES, and it has to be, or the real failure looks
# like a hang: W reports a missing file and RETURNS, so a script waiting only for "records"
# waits for the timeout and then blames the card for something the disk did.
send "W C:R.COM FROM-C.COM\r"
expect {
    -ex "records"           {}
    -ex "no such CP/M file" { bad "R.COM is not on C: -- the 24K image is missing the host-bridge utilities. disks/mits-88dcdd/cpm22/buffered/README.md says how to put them there." }
    -ex "no CP/M file"      { bad "R.COM is not on C: -- the 24K image is missing the host-bridge utilities. disks/mits-88dcdd/cpm22/buffered/README.md says how to put them there." }
    -ex "A0>"               { bad "W read nothing off C: and said nothing about it" }
    timeout                 { bad "W hung reading C:" }
}
expect -ex "A0>"

# WRITE: A: -> C:, across the two geometries, on one controller. HDIR.COM lands on the
# floppy under a new name, and then comes back out again to be weighed.
send "PIP C:NEW.COM=A:HDIR.COM\r"
expect {
    -ex "A0>"   {}
    -ex "ERROR" { bad "PIP could not write to C: -- the floppy is not writable behind the 8 MB disk" }
    timeout     { bad "PIP hung writing to C:" }
}
send "W C:NEW.COM TO-C.COM\r"
expect {
    -ex "records" {}
    timeout       { bad "W hung reading back what PIP wrote to C:" }
}
expect -ex "A0>"

# THE 8 MB BIOS FLUSHES ITS TRACK BUFFER FROM CONIN, NOT ON CLOSE (docs/boards/mits-dcdd.md).
# Nothing above has landed on the image until CP/M reads the keyboard again -- so give it
# something to read. Without this the last write is still in RAM when the machine exits.
send "\r\r\r"
expect -ex "A0>"

close
wait

proc same {a b why} {
    if {![file exists $a]} { bad "$why -- nothing came out of the machine at all ($a)" }
    set fa [open $a rb]; set da [read $fa]; close $fa
    set fb [open $b rb]; set db [read $fb]; close $fb
    if {$da ne $db} {
        bad "$why\n  [file size $a] bytes came back and [file size $b] were expected, and they are not the same bytes.\n  A file crossing between a 2048-track disk and a 77-track one on the same card is being CORRUPTED, not lost."
    }
}

same "$work/host/FROM-C.COM" "$src/cpm/hostbridge/R.COM" \
     "R.COM read off the 77-track disk is not R.COM"
same "$work/host/TO-C.COM"   "$src/cpm/hostbridge/HDIR.COM" \
     "HDIR.COM copied from the 8 MB disk to the 77-track disk came back different"

puts "OK: an 8 MB disk (${afree}k free) and a 77-track floppy (${cfree}k free) on the same\
      88-DCDD at once -- a file crossed between them in each direction, byte for byte."
exit 0
