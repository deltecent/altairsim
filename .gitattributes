# Keep line endings deterministic across checkouts.
#
# The machine .toml files are embedded byte-for-byte into the binary by
# cmake/embed_machines.cmake (as a raw unsigned-char array, HEX-read). A Windows
# checkout with core.autocrlf=true would rewrite them CRLF and change the embedded
# bytes -- so pin all text to LF, and mark the binary media so git never touches it.
* text=auto eol=lf

*.toml text eol=lf
*.exp  text eol=lf
*.cmake text eol=lf
*.md   text eol=lf

# .bat files are Windows-only and only ever run by cmd.exe. Store them CRLF so a
# checkout matches the platform they belong to -- the native convention there, and the
# one line ending cmd.exe is guaranteed to parse without surprises around labels/goto.
*.bat  text eol=crlf

# CP/M symbol-file fixtures are real toolchain output (tests/programs/symbols/README.md):
# their CRLF line endings and trailing ^Z padding are part of the format under test, so
# git must never normalise them. The README stays ordinary text.
tests/programs/symbols/*.SYM binary
tests/programs/symbols/*.PRN binary
tests/programs/symbols/*.MAC binary
tests/programs/symbols/*.ASM binary

# The symbolic-debugger example ships the same period toolchain set -- a listing, its
# source and the Intel HEX (examples/debugger/). They are CRLF like the real CP/M files
# they imitate; keep them byte-for-byte so a checkout matches on every platform. (.HEX is
# already binary globally below.)
examples/debugger/*.PRN binary
examples/debugger/*.ASM binary

# Period media and disk images are binary -- never munge.
*.DSK binary
*.dsk binary
*.bin binary
*.BIN binary
*.hex binary
*.HEX binary
*.keys binary
*.tap binary
*.TAP binary
*.wav binary
*.WAV binary
*.pdf binary
*.PDF binary

# The TREK80 ENTER script is a period artifact fetched byte-for-byte from the archive
# (docs/sources.md), CRLF line endings and all, and examples/sol/make-trek80-tape.sh
# derives the shipped tape from it. Normalising it would change the source of a
# reproducible build.
examples/sol/TREK80.ENT binary
